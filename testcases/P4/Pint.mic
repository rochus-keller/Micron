// pint.pas lines 90-434: load procedure
proc load()
begin
  init()
  // Open prd file
  prd := F.Open(@prdname, F.ReadOnly)
  if prd = nil then
    O.String("Error: cannot open "); O.String(@prdname); O.Ln
    errorFlag := true; return
  end
  prdEof := false
  prdEoln := false
  prdPos := 0
  prdLen := 0
  prdReadLine()  // read first line
  generate()
  pc := 0
  generate()
end load


// pint.pas lines 487-662: callsp
proc callsp()
  var line: boolean
      adptr: integer
      adelnt: integer
      ci: integer
      fad: integer
      cch: char
      r: real
      tmpReal: real
      tmpCh: char

  // pint.pas lines 517-527: writestr
  proc doWriteStr(toOutput: boolean)
    var wi: integer
        wj: integer
        wk: integer
        wad: integer
  begin
    wad := store[sp - 3].vi  // va
    wk := store[sp - 2].vi
    wj := store[sp - 1].vi
    // j and k are numbers of characters
    if wk > wj then
      for wi := 1 to wk - wj do
        if toOutput then O.String(" ")
        else prrWriteChar(" ") end
      end
    else wj := wk end
    for wi := 0 to wj - 1 do
      if toOutput then printChar(store[wad + wi].vi)
      else prrWriteChar(chr(store[wad + wi].vi)) end
    end
    sp := sp - 4
  end doWriteStr

begin // callsp
  if q = 0 then
    // get
    if store[sp].vi = inputadr then
      // getfile(input) - advance stdin, store lookahead at inputadr
      fad := store[sp].vi  // va = inputadr
      stdinAdvance()
      store[fad].vi := +ord(stdinCh)
      sp := sp - 1
    elsif store[sp].vi = prdadr then
      // getfile(prd) - advance prd
      sp := sp - 1
    else errori("get on output/prr file") end

  elsif q = 1 then
    // put
    if store[sp].vi = outputadr then
      // putfile(output) - write buffered char
      fad := store[sp].vi
      printChar(store[fad].vi)
      sp := sp - 1
    elsif store[sp].vi = prradr then
      fad := store[sp].vi
      prrWriteChar(chr(store[fad].vi))
      sp := sp - 1
    else errori("put on read file") end

  elsif q = 2 then
    // rst
    np := store[sp].vi  // va
    sp := sp - 1

  elsif q = 3 then
    // rln - readln
    if store[sp].vi = inputadr then
      // readln(input) - skip to next line, store lookahead
      stdinReadLn()
      store[inputadr].vi := +ord(stdinCh)
      sp := sp - 1
    elsif store[sp].vi = prdadr then
      prdReadLn()
      sp := sp - 1
    else errori("readln on output/prr file") end

  elsif q = 4 then
    // new
    ad := np - store[sp].vi
    if ad <= ep then errori("store overflow") end
    np := ad
    ad := store[sp - 1].vi  // va
    store[ad].vi := np       // va
    sp := sp - 2

  elsif q = 5 then
    // wln - writeln
    if store[sp].vi = outputadr then
      O.String(""); O.Ln
    elsif store[sp].vi = prradr then
      prrWriteLn()
    else errori("writeln on input/prd file") end
    sp := sp - 1

  elsif q = 6 then
    // wrs - write string
    if store[sp].vi = outputadr then
      doWriteStr(true)
    elsif store[sp].vi = prradr then
      doWriteStr(false)
    else errori("write on input/prd file") end

  elsif q = 7 then
    // eln - eoln
    if store[sp].vi = inputadr then
      // eoln(input) - check if at end of line on stdin
      if stdinEoln then store[sp].vi := 1 else store[sp].vi := 0 end
    else errori("eoln on output/prr file") end

  elsif q = 8 then
    // wri - write integer
    if store[sp].vi = outputadr then
      O.Int(store[sp - 2].vi, store[sp - 1].vi)
    elsif store[sp].vi = prradr then
      prrWriteInt(store[sp - 2].vi, store[sp - 1].vi)
    else errori("write on input/prd file") end
    sp := sp - 3

  elsif q = 9 then
    // wrr - write real
    if store[sp].vi = outputadr then
      O.Real(storeRealGet(sp - 2), store[sp - 1].vi)
    elsif store[sp].vi = prradr then
      // TODO: write real to prr
    end
    sp := sp - 3

  elsif q = 10 then
    // wrc - write char
    if store[sp].vi = outputadr then
      // pad with spaces for field width
      ci := store[sp - 1].vi
      while ci > 1 do O.String(" "); dec(ci) end
      printChar(store[sp - 2].vi)
    elsif store[sp].vi = prradr then
      ci := store[sp - 1].vi
      while ci > 1 do prrWriteChar(" "); dec(ci) end
      prrWriteChar(chr(store[sp - 2].vi))
    else errori("write on input/prd file") end
    sp := sp - 3

  elsif q = 11 then
    // rdi - read integer (pint.pas line 633)
    if store[sp].vi = inputadr then
      ad := store[sp - 1].vi  // va - address to store result
      stdinReadInt(@store[ad].vi)
      store[inputadr].vi := +ord(stdinCh)  // lookahead
      sp := sp - 2
    elsif store[sp].vi = prdadr then
      ad := store[sp - 1].vi
      prdReadInt(@store[ad].vi)
      sp := sp - 2
    else errori("read on output file") end

  elsif q = 12 then
    // rdr - read real (pint.pas line 639)
    if store[sp].vi = inputadr then
      ad := store[sp - 1].vi
      stdinReadReal(@tmpReal)
      storeRealPut(ad, tmpReal)
      store[inputadr].vi := +ord(stdinCh)
      sp := sp - 2
    elsif store[sp].vi = prdadr then
      ad := store[sp - 1].vi
      prdReadReal(@tmpReal)
      storeRealPut(ad, tmpReal)
      sp := sp - 2
    else errori("read on output file") end

  elsif q = 13 then
    // rdc - read char (pint.pas line 645)
    if store[sp].vi = inputadr then
      ad := store[sp - 1].vi
      stdinReadChar(@tmpCh)
      store[ad].vi := +ord(tmpCh)
      store[inputadr].vi := +ord(stdinCh)  // lookahead
      sp := sp - 2
    elsif store[sp].vi = prdadr then
      ad := store[sp - 1].vi
      prdReadChar(@tmpCh)
      store[ad].vi := +ord(tmpCh)
      sp := sp - 2
    else errori("read on output file") end

  elsif q = 14 then
    // sin
    storeRealPut(sp, M.sin(storeRealGet(sp)))
  elsif q = 15 then
    // cos
    storeRealPut(sp, M.cos(storeRealGet(sp)))
  elsif q = 16 then
    // exp
    storeRealPut(sp, M.exp(storeRealGet(sp)))
  elsif q = 17 then
    // log (ln in Pascal)
    storeRealPut(sp, M.ln(storeRealGet(sp)))
  elsif q = 18 then
    // sqt (sqrt in Pascal)
    storeRealPut(sp, M.sqrt(storeRealGet(sp)))
  elsif q = 19 then
    // atn (arctan in Pascal)
    storeRealPut(sp, M.arctan(storeRealGet(sp)))
  elsif q = 20 then
    // sav
    ad := store[sp].vi  // va
    store[ad].vi := np   // va
    sp := sp - 1
  end
end callsp

// pint.pas lines 664-1017: main interpreter loop
proc interpret()
  var s1: SetType
      s2: SetType
begin
  // pint.pas line 668
  pc := 0; sp := -1; mp := 0; np := +(maxstk + 1); ep := 5
  // Initialize stdin for read/readln support (Pascal's input file)
  stdinFile := F.System(F.Stdin)
  stdinEof := false; stdinEoln := false; stdinCh := " "
  store[inputadr].vi := +ord(" ")  // initial lookahead = space
  interpreting := true

  while interpreting and not errorFlag do
    // fetch
    if (pc mod 2) <> 0 then
      op := code[pc div 2].op2
      p := code[pc div 2].p2
      q := code[pc div 2].q2
    else
      op := code[pc div 2].op1
      p := code[pc div 2].p1
      q := code[pc div 2].q1
    end
    inc(pc)

    // execute
    if (op = 0) or ((op >= 105) and (op <= 109)) then
      // lod
      ad := base(p) + q
      inc(sp)
      store[sp] := store[ad]
      realstore[sp] := realstore[ad]

    elsif (op = 1) or ((op >= 65) and (op <= 69)) then
      // ldo
      inc(sp)
      store[sp] := store[q]
      realstore[sp] := realstore[q]

    elsif (op = 2) or ((op >= 70) and (op <= 74)) then
      // str
      store[base(p) + q] := store[sp]
      realstore[base(p) + q] := realstore[sp]
      dec(sp)

    elsif (op = 3) or ((op >= 75) and (op <= 79)) then
      // sro
      store[q] := store[sp]
      realstore[q] := realstore[sp]
      dec(sp)

    elsif op = 4 then
      // lda
      inc(sp)
      store[sp].vi := base(p) + q

    elsif op = 5 then
      // lao
      inc(sp)
      store[sp].vi := q

    elsif (op = 6) or ((op >= 80) and (op <= 84)) then
      // sto
      store[store[sp - 1].vi] := store[sp]
      realstore[store[sp - 1].vi] := realstore[sp]
      sp := sp - 2

    elsif op = 7 then
      // ldc
      inc(sp)
      if p = 1 then
        store[sp].vi := q
      elsif p = 6 then
        store[sp].vi := q  // char stored as ordinal
      elsif p = 3 then
        if q = 1 then store[sp].vi := 1 else store[sp].vi := 0 end  // boolean
      else
        store[sp].vi := maxstr  // nil
      end

    elsif op = 8 then
      // lci
      inc(sp)
      store[sp] := store[q]
      realstore[sp] := realstore[q]

    elsif (op = 9) or ((op >= 85) and (op <= 89)) then
      // ind
      ad := store[sp].vi + q
      store[sp] := store[ad]
      realstore[sp] := realstore[ad]

    elsif (op = 10) or ((op >= 90) and (op <= 94)) then
      // inc
      store[sp].vi := store[sp].vi + q

    elsif op = 11 then
      // mst
      store[sp + 2].vi := base(p)  // sl (static link)
      store[sp + 3].vi := mp       // dl (dynamic link)
      store[sp + 4].vi := ep       // ep save
      sp := sp + 5

    elsif op = 12 then
      // cup
      mp := sp - (p + 4)
      store[mp + 4].vi := pc  // return address
      pc := q

    elsif op = 13 then
      // ent
      if p = 1 then
        sp := mp + q
        if sp > np then errori("store overflow") end
      else
        ep := sp + q
        if ep > np then errori("store overflow") end
      end

    elsif op = 14 then
      // ret
      if p = 0 then sp := mp - 1
      else sp := mp end
      pc := store[mp + 4].vi
      ep := store[mp + 3].vi
      mp := store[mp + 2].vi

    elsif op = 15 then
      // csp
      callsp()

    elsif op = 16 then
      // ixa
      i := store[sp].vi
      dec(sp)
      store[sp].vi := q * i + store[sp].vi

    elsif op = 17 then
      // equ
      dec(sp)
      if p = 1 then b := store[sp].vi = store[sp + 1].vi
      elsif p = 0 then b := store[sp].vi = store[sp + 1].vi  // address
      elsif p = 6 then b := store[sp].vi = store[sp + 1].vi  // char
      elsif p = 2 then b := realstore[sp] = realstore[sp + 1]
      elsif p = 3 then b := store[sp].vi = store[sp + 1].vi  // bool
      elsif p = 4 then b := setEq(storeSetGet(sp), storeSetGet(sp + 1))
      elsif p = 5 then doCompare(); b := b
      end
      if b then store[sp].vi := 1 else store[sp].vi := 0 end

    elsif op = 18 then
      // neq
      dec(sp)
      if p = 0 then b := store[sp].vi <> store[sp + 1].vi
      elsif p = 1 then b := store[sp].vi <> store[sp + 1].vi
      elsif p = 6 then b := store[sp].vi <> store[sp + 1].vi
      elsif p = 2 then b := realstore[sp] <> realstore[sp + 1]
      elsif p = 3 then b := store[sp].vi <> store[sp + 1].vi
      elsif p = 4 then b := not setEq(storeSetGet(sp), storeSetGet(sp + 1))
      elsif p = 5 then doCompare(); b := not b
      end
      if b then store[sp].vi := 1 else store[sp].vi := 0 end

    elsif op = 19 then
      // geq
      dec(sp)
      if p = 0 then errori("<,<=,>,>= for address")
      elsif p = 1 then b := store[sp].vi >= store[sp + 1].vi
      elsif p = 6 then b := store[sp].vi >= store[sp + 1].vi
      elsif p = 2 then b := realstore[sp] >= realstore[sp + 1]
      elsif p = 3 then b := store[sp].vi >= store[sp + 1].vi
      elsif p = 4 then b := setGeq(storeSetGet(sp), storeSetGet(sp + 1))
      elsif p = 5 then doCompare(); b := b or (store[i1 + i].vi >= store[i2 + i].vi)
      end
      if b then store[sp].vi := 1 else store[sp].vi := 0 end

    elsif op = 20 then
      // grt
      dec(sp)
      if p = 0 then errori("<,<=,>,>= for address")
      elsif p = 1 then b := store[sp].vi > store[sp + 1].vi
      elsif p = 6 then b := store[sp].vi > store[sp + 1].vi
      elsif p = 2 then b := realstore[sp] > realstore[sp + 1]
      elsif p = 3 then b := store[sp].vi > store[sp + 1].vi
      elsif p = 4 then errori("set inclusion")
      elsif p = 5 then doCompare(); b := (not b) and (store[i1 + i].vi > store[i2 + i].vi)
      end
      if b then store[sp].vi := 1 else store[sp].vi := 0 end

    elsif op = 21 then
      // leq
      dec(sp)
      if p = 0 then errori("<,<=,>,>= for address")
      elsif p = 1 then b := store[sp].vi <= store[sp + 1].vi
      elsif p = 6 then b := store[sp].vi <= store[sp + 1].vi
      elsif p = 2 then b := realstore[sp] <= realstore[sp + 1]
      elsif p = 3 then b := store[sp].vi <= store[sp + 1].vi
      elsif p = 4 then b := setLeq(storeSetGet(sp), storeSetGet(sp + 1))
      elsif p = 5 then doCompare(); b := b or (store[i1 + i].vi <= store[i2 + i].vi)
      end
      if b then store[sp].vi := 1 else store[sp].vi := 0 end

    elsif op = 22 then
      // les
      dec(sp)
      if p = 0 then errori("<,<=,>,>= for address")
      elsif p = 1 then b := store[sp].vi < store[sp + 1].vi
      elsif p = 6 then b := store[sp].vi < store[sp + 1].vi
      elsif p = 2 then b := realstore[sp] < realstore[sp + 1]
      elsif p = 3 then b := store[sp].vi < store[sp + 1].vi
      elsif p = 5 then doCompare(); b := (not b) and (store[i1 + i].vi < store[i2 + i].vi)
      end
      if b then store[sp].vi := 1 else store[sp].vi := 0 end

    elsif op = 23 then
      // ujp
      pc := q

    elsif op = 24 then
      // fjp
      if store[sp].vi = 0 then pc := q end  // vb false = 0
      dec(sp)

    elsif op = 25 then
      // xjp
      pc := store[sp].vi + q
      dec(sp)

    elsif op = 95 then
      // chka
      if (store[sp].vi < np) or (store[sp].vi > (maxstr - q)) then
        errori("bad pointer value")
      end

    elsif (op = 26) or ((op >= 96) and (op <= 99)) then
      // chk
      if (store[sp].vi < store[q - 1].vi) or (store[sp].vi > store[q].vi) then
        errori("value out of range")
      end

    elsif op = 27 then
      // eof
      i := store[sp].vi
      if i = inputadr then
        store[sp].vi := 0  // eof(input) - false for now
      else errori("code in error") end

    elsif op = 28 then
      // adi
      dec(sp)
      store[sp].vi := store[sp].vi + store[sp + 1].vi

    elsif op = 29 then
      // adr
      dec(sp)
      realstore[sp] := realstore[sp] + realstore[sp + 1]

    elsif op = 30 then
      // sbi
      dec(sp)
      store[sp].vi := store[sp].vi - store[sp + 1].vi

    elsif op = 31 then
      // sbr
      dec(sp)
      realstore[sp] := realstore[sp] - realstore[sp + 1]

    elsif op = 32 then
      // sgs
      storeSetPut(sp, setOf(store[sp].vi))

    elsif op = 33 then
      // flt
      realstore[sp] := flt(store[sp].vi)

    elsif op = 34 then
      // flo
      realstore[sp - 1] := flt(store[sp - 1].vi)

    elsif op = 35 then
      // trc
      store[sp].vi := floor(realstore[sp])

    elsif op = 36 then
      // ngi
      store[sp].vi := -store[sp].vi

    elsif op = 37 then
      // ngr
      realstore[sp] := -realstore[sp]

    elsif op = 38 then
      // sqi
      store[sp].vi := store[sp].vi * store[sp].vi

    elsif op = 39 then
      // sqr (real)
      realstore[sp] := realstore[sp] * realstore[sp]

    elsif op = 40 then
      // abi
      store[sp].vi := abs(store[sp].vi)

    elsif op = 41 then
      // abr
      if realstore[sp] < 0.0 then realstore[sp] := -realstore[sp] end

    elsif op = 42 then
      // not
      if store[sp].vi = 0 then store[sp].vi := 1
      else store[sp].vi := 0 end

    elsif op = 43 then
      // and
      dec(sp)
      if (store[sp].vi <> 0) and (store[sp + 1].vi <> 0) then store[sp].vi := 1
      else store[sp].vi := 0 end

    elsif op = 44 then
      // ior
      dec(sp)
      if (store[sp].vi <> 0) or (store[sp + 1].vi <> 0) then store[sp].vi := 1
      else store[sp].vi := 0 end

    elsif op = 45 then
      // dif
      dec(sp)
      storeSetPut(sp, setDiff(storeSetGet(sp), storeSetGet(sp + 1)))

    elsif op = 46 then
      // int (set intersection)
      dec(sp)
      storeSetPut(sp, setInter(storeSetGet(sp), storeSetGet(sp + 1)))

    elsif op = 47 then
      // uni
      dec(sp)
      storeSetPut(sp, setUnion(storeSetGet(sp), storeSetGet(sp + 1)))

    elsif op = 48 then
      // inn
      dec(sp)
      i := store[sp].vi
      if setIn(i, storeSetGet(sp + 1)) then store[sp].vi := 1
      else store[sp].vi := 0 end

    elsif op = 49 then
      // mod
      dec(sp)
      store[sp].vi := store[sp].vi mod store[sp + 1].vi

    elsif op = 50 then
      // odd
      if (store[sp].vi mod 2) <> 0 then store[sp].vi := 1
      else store[sp].vi := 0 end

    elsif op = 51 then
      // mpi
      dec(sp)
      store[sp].vi := store[sp].vi * store[sp + 1].vi

    elsif op = 52 then
      // mpr
      dec(sp)
      realstore[sp] := realstore[sp] * realstore[sp + 1]

    elsif op = 53 then
      // dvi
      dec(sp)
      store[sp].vi := store[sp].vi div store[sp + 1].vi

    elsif op = 54 then
      // dvr
      dec(sp)
      realstore[sp] := realstore[sp] / realstore[sp + 1]

    elsif op = 55 then
      // mov
      i1 := store[sp - 1].vi  // va
      i2 := store[sp].vi      // va
      sp := sp - 2
      for i := 0 to q - 1 do
        store[i1 + i] := store[i2 + i]
        realstore[i1 + i] := realstore[i2 + i]
      end

    elsif (op = 56) then
      // lca
      inc(sp)
      store[sp].vi := q  // va = address of string in store

    elsif (op = 57) or ((op >= 100) and (op <= 104)) then
      // dec
      store[sp].vi := store[sp].vi - q

    elsif op = 58 then
      // stp
      interpreting := false

    elsif op = 59 then
      // ord - no-op (just changes tag)

    elsif op = 60 then
      // chr - no-op (just changes tag)

    elsif op = 61 then
      // ujc
      errori("case - error")

    end  // if chain for opcodes
  end  // while interpreting
end interpret

var 
  argptr: A.String
  argidx: integer

begin
  O.String("Pint starting..."); O.Ln
  errorFlag := false

  // Get prd file name from command line args
  if A.Count() < 2 then
    O.String("Usage: Pint <pcode-file>"); O.Ln
    return
  end
  argptr := A.Arg(1)
  if argptr = nil then
    O.String("Error: cannot read argument"); O.Ln
    return
  end
  // Copy arg to prdname
  argidx := 0
  while (argidx < 255) and (argptr[argidx] <> 0X) do
    prdname[argidx] := argptr[argidx]; inc(argidx)
  end
  prdname[argidx] := 0X
  O.String("Opening prd file: "); O.String(@prdname); O.Ln

  load()
  O.String("Load complete."); O.Ln
  if not errorFlag then
    interpret()
  end

end Pint
