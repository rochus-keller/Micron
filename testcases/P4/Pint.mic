(* Micron port of the 1976 P4 Pascal Compiler
 * Pint.mic - P4 Pascal P-code Interpreter
 * pint.pas was originally written by K. Jensen, N. Wirth, Ch. Jacobi.
 * We used the version of the 1982 book: "Pascal Implementation" by Pemberton & Daniels
 *   https://homepages.cwi.nl/~steven/pascal/book/pascalimplementation.html
 * This file includes references to the Pascal pint.pas version in the
 *   form of "// pint.pas lines from-to" comments; use them to look up the 
 *   original comments  and the corresponding explanation in the book.
 * Migrated from Pascal in 2026 by me@rochus-keller.ch, made available under
 * the terms of the GNU General Public License (GPL) versions 2.0 or 3.0 
 *)
 
module Pint

import F := Files
       A := Args
       O := Out
       M := Math

// pint.pas lines 21-36: constants
const 
  codemax   = 8650
  pcmax     = 17500
  maxstk    = 13650   // size of variable store
  overi     = 13655   // size of integer constant table = 5
  overr     = 13660   // size of real constant table = 5
  overs     = 13730   // size of set constant table = 70
  overb     = 13820
  overm     = 18000
  maxstr    = 18001
  largeint  = 26144
  begincode = 3
  inputadr  = 5
  outputadr = 6
  prdadr    = 7
  prradr    = 8
  duminst   = 62
  maxlabel  = 1850
  strglgth  = 16      // string constant length in store

// Helper: ordinal of '0' as integer for digit parsing
  ord0 = +ord("0")

// pint.pas lines 38-46: types
// datatype = (undef,int,reel,bool,sett,adr,mark,car)
// We use integer constants for datatype
// settype = set of 0..58 -> two uint32 record (59 bits needed)
type 
  SetType = record lo: uint32; hi: uint32 end

// pint.pas lines 43,45: alfa = packed array[1..10] of char
// In Micron, we use array 11 of char (0-based, 10 chars + null)
  Alfa = array 11 of char

// pint.pas lines 47-54: code record
// packed record op1:bit6; p1:bit4; q1:bit20; op2:bit6; p2:bit4; q2:bit20 end
  CodeRec = record
    op1: integer
    p1:  integer
    q1:  integer
    op2: integer
    p2:  integer
    q2:  integer
  end

// pint.pas lines 58-68: store - variant record
// We represent each store cell as a 64-bit value.
// Access vi (integer), vr (real), vb (boolean), vc (char), va (address), vs (set)
// through the same memory. Since Micron doesn't have variant records at module level
// in the same way, we use a record with an integer field and cast as needed.
// For simplicity in the interpreter, we'll use an integer array and
// reinterpret for real values via pointer casting.
  StoreCell = record
    vi: integer   // also used for va (address), vm (mark), vb (as 0/1), vc (as ordinal)
  end

// For real values we need to store them differently
// We'll use a parallel real array for cells that hold reals
var 
  realstore: array 18001 of real

// pint.pas lines 47-68: global variables
  code: array 4326 of CodeRec  // codemax/2 + 1
  pc: integer          // program address register
  op: integer          // instruction register - opcode
  p:  integer          // instruction register - p field
  q:  integer          // instruction register - q field

  store: array 18001 of StoreCell  // 0..overm
  mp: integer          // points to beginning of data segment
  sp: integer          // points to top of stack
  np: integer          // points to top of dynamically allocated area
  ep: integer          // points to maximum extent of stack

  interpreting: boolean

// pint.pas line 76: prd, prr files
  prd: F.File          // prd for read only
  prr: F.File          // prr for write only
  stdinFile: F.File    // stdin handle for read/readln

// pint.pas lines 78-80: instruction and sp tables
  instr: array 63 of Alfa         // mnemonic instruction codes (0..62)
  cop: array 63 of integer        // opcode mapping
  sptable: array 21 of Alfa       // standard functions and procedures (0..20)

// pint.pas lines 83-86: locally used for interpreting
  ad: integer
  ad1: integer
  b: boolean
  i: integer
  j: integer
  i1: integer
  i2: integer
  c: char

// pint.pas line 91-92: load procedure locals (made module-level)
  icp: integer         // pointer to next free integer constant position
  rcp: integer         // pointer to next free real constant position
  scp: integer         // pointer to next free set constant position
  bcp: integer         // pointer to next free boundary constant position
  mcp: integer         // pointer to next free multiple (string) constant position

const 
  entered = 0
  defined = 1

type 
  LabelRec = record
    val: integer
    st:  integer   // 0=entered, 1=defined
  end

var 
  labeltab: array 1851 of LabelRec  // 0..maxlabel
  labelvalue: integer

// Word buffer for reading instruction names
  word: array 11 of char  // 1..10 in Pascal, we use 0..9

// Flag for error-goto simulation (Pascal's goto 1)
  errorFlag: boolean

// prd reading helpers - since we can't use Pascal's read(prd,ch) directly
// we need to buffer the prd file and parse it character by character
  prdBuf: array 256 of char   // current line buffer
  prdPos: integer              // current position in buffer
  prdLen: integer              // length of current line
  prdEof: boolean              // end of file flag
  prdEoln: boolean             // end of line flag
  ch: char                     // current character from prd

// stdin reading helpers - for read/readln from stdin (Pascal's input file)
  stdinCh: char              // lookahead character from stdin
  stdinEof: boolean          // end of file on stdin
  stdinEoln: boolean         // end of line on stdin

// Output file name from Args
  prdname: array 256 of char
  prrname: array 256 of char


// File I/O helpers for prd (read-only P-code input)


// Read one line from prd into prdBuf
proc prdReadLine()
  var idx: integer
      byt: byte
      ok: boolean
begin
  if prdEof then return end
  idx := 0
  loop
    ok := F.Read(prd, @byt)
    if F.Eof(prd) then
      if idx = 0 then prdEof := true end
      prdLen := idx
      prdPos := 0
      prdEoln := true
      return
    end
    if byt = 0AH then  // newline
      prdBuf[idx] := 0X
      prdLen := idx
      prdPos := 0
      prdEoln := false
      return
    end
    if byt = 0DH then  // carriage return
      // check for following LF
      ok := F.Read(prd, @byt)
      // CR or CR/LF - treat as newline
      prdBuf[idx] := 0X
      prdLen := idx
      prdPos := 0
      prdEoln := false
      return
    end
    if idx < 255 then
      prdBuf[idx] := CHR(byt)
      inc(idx)
    end
  end
end prdReadLine

// Read next character from prd
proc prdRead(chp: ^char)
begin
  if prdPos < prdLen then
    chp^ := prdBuf[prdPos]
    inc(prdPos)
    prdEoln := (prdPos >= prdLen)
  else
    chp^ := " "
    prdEoln := true
  end
end prdRead

// Check if at end of line
proc prdIsEoln(): boolean
begin
  return prdPos >= prdLen
end prdIsEoln

// Read to end of line and advance to next line
proc prdReadLn()
begin
  prdReadLine()
end prdReadLn

// Skip spaces and read an integer from prd
proc prdReadInt(valp: ^integer)
  var neg: boolean
      ch: char
      val: integer
      d: integer
begin
  val := 0
  neg := false
  // skip spaces
  while (prdPos < prdLen) and (prdBuf[prdPos] = " ") do
    inc(prdPos)
  end
  if prdPos < prdLen then
    if prdBuf[prdPos] = "-" then
      neg := true; inc(prdPos)
    elsif prdBuf[prdPos] = "+" then
      inc(prdPos)
    end
  end
  while (prdPos < prdLen) and (prdBuf[prdPos] >= "0") and (prdBuf[prdPos] <= "9") do
    d := +ord(prdBuf[prdPos]) - ord0
    val := val * 10 + d
    inc(prdPos)
  end
  if neg then val := -val end
  valp^ := val
  prdEoln := (prdPos >= prdLen)
end prdReadInt

// Read a real number from prd
proc prdReadReal(valp: ^real)
  var intpart: integer
      fracpart: real
      divisor: real
      neg: boolean
      expval: integer
      expneg: boolean
      ch: char
      val: real
      d: integer
begin
  val := 0.0
  neg := false
  // skip spaces
  while (prdPos < prdLen) and (prdBuf[prdPos] = " ") do
    inc(prdPos)
  end
  if prdPos < prdLen then
    if prdBuf[prdPos] = "-" then
      neg := true; inc(prdPos)
    elsif prdBuf[prdPos] = "+" then
      inc(prdPos)
    end
  end
  // integer part
  intpart := 0
  while (prdPos < prdLen) and (prdBuf[prdPos] >= "0") and (prdBuf[prdPos] <= "9") do
    d := +ord(prdBuf[prdPos]) - ord0
    intpart := intpart * 10 + d
    inc(prdPos)
  end
  val := flt(intpart)
  // fractional part
  if (prdPos < prdLen) and (prdBuf[prdPos] = ".") then
    inc(prdPos)
    fracpart := 0.0
    divisor := 1.0
    while (prdPos < prdLen) and (prdBuf[prdPos] >= "0") and (prdBuf[prdPos] <= "9") do
      d := +ord(prdBuf[prdPos]) - ord0
      fracpart := fracpart * 10.0 + flt(d)
      divisor := divisor * 10.0
      inc(prdPos)
    end
    val := val + fracpart / divisor
  end
  // exponent
  if (prdPos < prdLen) and ((prdBuf[prdPos] = "e") or (prdBuf[prdPos] = "E")) then
    inc(prdPos)
    expneg := false
    if prdPos < prdLen then
      if prdBuf[prdPos] = "-" then
        expneg := true; inc(prdPos)
      elsif prdBuf[prdPos] = "+" then
        inc(prdPos)
      end
    end
    expval := 0
    while (prdPos < prdLen) and (prdBuf[prdPos] >= "0") and (prdBuf[prdPos] <= "9") do
      d := +ord(prdBuf[prdPos]) - ord0
      expval := expval * 10 + d
      inc(prdPos)
    end
    // apply exponent: val := val * 10^expval
    i := 0
    if expneg then
      while i < expval do val := val / 10.0; inc(i) end
    else
      while i < expval do val := val * 10.0; inc(i) end
    end
  end
  if neg then val := -val end
  valp^ := val
  prdEoln := (prdPos >= prdLen)
end prdReadReal

// Read a single char from prd
proc prdReadChar(chp: ^char)
begin
  if prdPos < prdLen then
    chp^ := prdBuf[prdPos]
    inc(prdPos)
  else
    chp^ := " "
  end
  prdEoln := (prdPos >= prdLen)
end prdReadChar


// Stdin reading helpers - for Pascal's input file (read/readln from stdin)

proc stdinAdvance()
  // Read one character from stdin into stdinCh
  var byt: byte
begin
  if stdinEof then return end
  if not F.Read(stdinFile, @byt) then
    stdinEof := true; stdinCh := " "; stdinEoln := true
  elsif byt = 10 then  // newline
    stdinEoln := true; stdinCh := " "
  elsif byt = 13 then  // carriage return - skip, read next
    if not F.Read(stdinFile, @byt) then
      stdinEof := true; stdinCh := " "; stdinEoln := true
    elsif byt = 10 then
      stdinEoln := true; stdinCh := " "
    else
      stdinEoln := false; stdinCh := chr(+byt)
    end
  else
    stdinEoln := false; stdinCh := chr(+byt)
  end
end stdinAdvance

proc stdinReadLn()
  // Skip to end of current line on stdin
begin
  while not stdinEoln and not stdinEof do stdinAdvance() end
  if not stdinEof then stdinAdvance() end  // consume the newline, read next char
end stdinReadLn

proc stdinReadInt(valp: ^integer)
  // Read a text-format integer from stdin (Pascal's read(input, i))
  var neg: boolean
      n: integer
      d: integer
begin
  // skip whitespace (spaces, tabs, newlines)
  while (stdinCh = " ") or (stdinCh = 9X) or stdinEoln do
    if stdinEof then valp^ := 0; return end
    stdinAdvance()
  end
  neg := false
  if stdinCh = "-" then neg := true; stdinAdvance()
  elsif stdinCh = "+" then stdinAdvance() end
  n := 0
  while (stdinCh >= "0") and (stdinCh <= "9") do
    d := +ord(stdinCh) - ord0
    n := n * 10 + d
    stdinAdvance()
  end
  if neg then n := -n end
  valp^ := n
end stdinReadInt

proc stdinReadReal(valp: ^real)
  // Read a text-format real from stdin (Pascal's read(input, r))
  var neg: boolean
      n: real
      fracDiv: real
      expNeg: boolean
      expVal: integer
      d: integer
begin
  // skip whitespace
  while (stdinCh = " ") or (stdinCh = 9X) or stdinEoln do
    if stdinEof then valp^ := 0.0; return end
    stdinAdvance()
  end
  neg := false
  if stdinCh = "-" then neg := true; stdinAdvance()
  elsif stdinCh = "+" then stdinAdvance() end
  n := 0.0
  while (stdinCh >= "0") and (stdinCh <= "9") do
    d := +ord(stdinCh) - ord0
    n := n * 10.0 + flt(d)
    stdinAdvance()
  end
  if stdinCh = "." then
    stdinAdvance()
    fracDiv := 10.0
    while (stdinCh >= "0") and (stdinCh <= "9") do
      d := +ord(stdinCh) - ord0
      n := n + flt(d) / fracDiv
      fracDiv := fracDiv * 10.0
      stdinAdvance()
    end
  end
  if (stdinCh = "e") or (stdinCh = "E") then
    stdinAdvance()
    expNeg := false; expVal := 0
    if stdinCh = "-" then expNeg := true; stdinAdvance()
    elsif stdinCh = "+" then stdinAdvance() end
    while (stdinCh >= "0") and (stdinCh <= "9") do
      d := +ord(stdinCh) - ord0
      expVal := expVal * 10 + d
      stdinAdvance()
    end
    if expNeg then
      while expVal > 0 do n := n / 10.0; dec(expVal) end
    else
      while expVal > 0 do n := n * 10.0; dec(expVal) end
    end
  end
  if neg then n := -n end
  valp^ := n
end stdinReadReal

proc stdinReadChar(chp: ^char)
  // Read a single character from stdin (Pascal's read(input, c))
begin
  chp^ := stdinCh
  stdinAdvance()
end stdinReadChar


// Output helpers

proc printChar(code: integer)
begin
  O.Char(chr(code))
end printChar

// Write to prr file helpers
proc prrWriteChar(c: char)
begin
  if prr <> nil then
    F.Write(prr, ord(c))
  end
end prrWriteChar

proc prrWriteStr(s: ^array of char)
  var k: integer
begin
  k := 0
  while s[k] <> 0X do
    prrWriteChar(s[k]); inc(k)
  end
end prrWriteStr

proc prrWriteInt(val: integer; width: integer)
  var buf: array 20 of char
      l: integer
      neg: boolean
      tmp: integer
      k: integer
begin
  if val < 0 then neg := true; tmp := -val
  else neg := false; tmp := val end
  l := 0
  if tmp = 0 then
    buf[0] := "0"; l := 1
  else
    while tmp > 0 do
      buf[l] := chr(+ord("0") + (tmp mod 10))
      tmp := tmp div 10
      inc(l)
    end
  end
  if neg then buf[l] := "-"; inc(l) end
  k := l
  while k < width do prrWriteChar(" "); inc(k) end
  k := l - 1
  while k >= 0 do prrWriteChar(buf[k]); dec(k) end
end prrWriteInt

proc prrWriteLn()
begin
  prrWriteChar(0AX)
end prrWriteLn


// Set operations for settype (set of 0..58)
proc setEmpty(): SetType
  var r: SetType
begin
  r.lo := 0; r.hi := 0
  return r
end setEmpty

proc setOf(elem: integer): SetType
  var r: SetType
begin
  r.lo := 0; r.hi := 0
  if (elem >= 0) and (elem <= 58) then
    if elem < 32 then r.lo := shl(1, val(uint32, elem))
    else r.hi := shl(1, val(uint32, elem - 32)) end
  end
  return r
end setOf

proc setAdd(s: SetType; elem: integer): SetType
  var b: SetType
begin
  b := setOf(elem)
  s.lo := bor(s.lo, b.lo); s.hi := bor(s.hi, b.hi)
  return s
end setAdd

proc setUnion(a: SetType; b: SetType): SetType
  var r: SetType
begin
  r.lo := bor(a.lo, b.lo); r.hi := bor(a.hi, b.hi)
  return r
end setUnion

proc setInter(a: SetType; b: SetType): SetType
  var r: SetType
begin
  r.lo := band(a.lo, b.lo); r.hi := band(a.hi, b.hi)
  return r
end setInter

proc setDiff(a: SetType; b: SetType): SetType
  var r: SetType
begin
  r.lo := band(a.lo, bnot(b.lo)); r.hi := band(a.hi, bnot(b.hi))
  return r
end setDiff

proc setIn(elem: integer; s: SetType): boolean
begin
  if (elem >= 0) and (elem <= 58) then
    if elem < 32 then return band(s.lo, shl(1, val(uint32, elem))) <> 0
    else return band(s.hi, shl(1, val(uint32, elem - 32))) <> 0 end
  end
  return false
end setIn

proc setEq(a: SetType; b: SetType): boolean
begin return (a.lo = b.lo) and (a.hi = b.hi) end setEq

proc setLeq(a: SetType; b: SetType): boolean
// a <= b means a is subset of b: (a AND b) = a
begin return (band(a.lo, b.lo) = a.lo) and (band(a.hi, b.hi) = a.hi) end setLeq

proc setGeq(a: SetType; b: SetType): boolean
// a >= b means a is superset of b: (a AND b) = b
begin return (band(a.lo, b.lo) = b.lo) and (band(a.hi, b.hi) = b.hi) end setGeq

// Store a set value into store cells (uses 2 consecutive cells for lo/hi)
// We store uint32 in the integer field via a shared array
var 
  setlo: array 18001 of uint32  // parallel array for set lo words
  sethi: array 18001 of uint32  // parallel array for set hi words

proc storeSetPut(idx: integer; s: SetType)
begin
  setlo[idx] := s.lo
  sethi[idx] := s.hi
end storeSetPut

proc storeSetGet(idx: integer): SetType
  var r: SetType
begin
  r.lo := setlo[idx]
  r.hi := sethi[idx]
  return r
end storeSetGet

// Store a real value
proc storeRealPut(idx: integer; r: real)
begin
  realstore[idx] := r
end storeRealPut

proc storeRealGet(idx: integer): real
begin
  return realstore[idx]
end storeRealGet


// pint.pas lines 167-171: errorl - error in loading
proc errorl(const msg: array 40 of char)
begin
  O.String(""); O.Ln
  O.String(@msg); O.Ln
  errorFlag := true
end errorl

// pint.pas lines 438-465: pmd and errori
proc pmd()
  var s: integer
  var cnt: integer
begin
  O.String(" pc ="); O.Int(pc - 1, 5)
  O.String(" op ="); O.Int(op, 3)
  O.String("  sp ="); O.Int(sp, 5)
  O.String("  mp ="); O.Int(mp, 5)
  O.String("  np ="); O.Int(np, 5)
  O.String(""); O.Ln
  O.String("--------------------------------------"); O.Ln
  s := sp; cnt := 0
  while s >= 0 do
    O.Int(s, 6)
    if abs(store[s].vi) < 2147483647 then O.Int(store[s].vi, 0)
    else O.String("too big ") end
    dec(s)
    inc(cnt)
    if cnt = 4 then O.String(""); O.Ln; cnt := 0 end
  end
  s := maxstk
  while s >= np do
    O.Int(s, 6)
    if abs(store[s].vi) < 2147483647 then O.Int(store[s].vi, 0)
    else O.String("too big ") end
    dec(s)
    inc(cnt)
    if cnt = 4 then O.String(""); O.Ln; cnt := 0 end
  end
end pmd

proc errori(const msg: array 40 of char)
begin
  O.String(""); O.Ln
  O.String(@msg); O.Ln
  pmd()
  errorFlag := true
end errori

// pint.pas lines 467-474: base function
proc base(ld: integer): integer
  var ad: integer
begin
  ad := mp
  while ld > 0 do
    ad := store[ad + 1].vi  // vm field = vi
    dec(ld)
  end
  return ad
end base

// pint.pas lines 476-485: compare
proc doCompare()
begin
  i1 := store[sp].vi      // va = vi (address)
  i2 := store[sp + 1].vi
  i := 0; b := true
  while b and (i <> q) do
    if store[i1 + i].vi = store[i2 + i].vi then inc(i)
    else b := false end
  end
end doCompare

// pint.pas lines 173-198: update
proc update(x: integer)
  var curr: integer
      succ: integer
      endlist: boolean
begin
  if labeltab[x].st = defined then
    errorl("duplicated label")
  else
    if labeltab[x].val <> -1 then  // forward reference(s)
      curr := labeltab[x].val
      endlist := false
      while not endlist do
        if (curr mod 2) <> 0 then
          succ := code[curr div 2].q2
          code[curr div 2].q2 := labelvalue
        else
          succ := code[curr div 2].q1
          code[curr div 2].q1 := labelvalue
        end
        if succ = -1 then endlist := true
        else curr := succ end
      end
    end
    labeltab[x].st := defined
    labeltab[x].val := labelvalue
  end
end update

// pint.pas lines 228-235: lookup
proc lookup(x: integer)
begin
  if labeltab[x].st = entered then
    q := labeltab[x].val
    labeltab[x].val := pc
  elsif labeltab[x].st = defined then
    q := labeltab[x].val
  end
end lookup

// pint.pas lines 237-241: labelsearch
proc labelsearch()
  var x: integer
begin
  while (ch <> "l") and not prdIsEoln() do prdReadChar(@ch) end
  prdReadInt(@x)
  lookup(x)
end labelsearch

// pint.pas lines 243-248: getname
proc getname(name: ^Alfa)
  var k: integer
begin
  word[0] := ch
  prdReadChar(@word[1])
  prdReadChar(@word[2])
  if not prdIsEoln() then prdReadChar(@ch) end  // next character
  // pack word into name (copy first 10 chars, pad with spaces)
  for k := 0 to 9 do name[k] := word[k] end
  name[10] := 0X
end getname

// pint.pas lines 250-264: typesymbol
proc typesymbol()
  var ti: integer
begin
  if ch <> "i" then
    if ch = "a" then ti := 0
    elsif ch = "r" then ti := 1
    elsif ch = "s" then ti := 2
    elsif ch = "b" then ti := 3
    elsif ch = "c" then ti := 4
    else ti := 0 end
    op := cop[op] + ti
  end
end typesymbol

// pint.pas lines 223-427: assemble
proc assemble()
  var name: Alfa
      ab: boolean
      r: real
      s: SetType
      c1: char
      ai: integer
      s1: integer
      lb: integer
      ub: integer
      skipStore: boolean  // replaces goto 1
begin
  skipStore := false
  p := 0; q := 0; op := 0
  getname(@name)
  // instr[duminst] := name
  for ai := 0 to 9 do instr[duminst][ai] := name[ai] end
  instr[duminst][10] := 0X


  while instr[op] <> name do inc(op) end
  if op = duminst then errorl("illegal instruction"); return end

  // pint.pas lines 272-416: case op - get parameters p, q
  if (op >= 17) and (op <= 22) then
    // equ,neq,geq,grt,leq,les
    if ch = "a" then // p = 0
    elsif ch = "i" then p := 1
    elsif ch = "r" then p := 2
    elsif ch = "b" then p := 3
    elsif ch = "s" then p := 4
    elsif ch = "c" then p := 6
    elsif ch = "m" then p := 5; prdReadInt(@q)
    end

  elsif (op = 0) or (op = 2) then
    // lod, str
    typesymbol(); prdReadInt(@p); prdReadInt(@q)

  elsif op = 4 then
    // lda
    prdReadInt(@p); prdReadInt(@q)

  elsif op = 12 then
    // cup
    prdReadInt(@p); labelsearch()

  elsif op = 11 then
    // mst
    prdReadInt(@p)

  elsif op = 14 then
    // ret
    if ch = "p" then p := 0
    elsif ch = "i" then p := 1
    elsif ch = "r" then p := 2
    elsif ch = "c" then p := 3
    elsif ch = "b" then p := 4
    elsif ch = "a" then p := 5
    end

  elsif (op = 5) or (op = 16) or (op = 55) then
    // lao, ixa, mov
    prdReadInt(@q)

  elsif (op = 1) or (op = 3) or (op = 9) or (op = 10) or (op = 57) then
    // ldo, sro, ind, inc, dec
    typesymbol(); prdReadInt(@q)

  elsif (op = 23) or (op = 24) or (op = 25) then
    // ujp, fjp, xjp
    labelsearch()

  elsif op = 13 then
    // ent
    prdReadInt(@p); labelsearch()

  elsif op = 15 then
    // csp
    for ai := 1 to 9 do prdReadChar(@ch) end
    getname(@name)

    while name <> sptable[q] do inc(q) end

  elsif op = 7 then
    // ldc
    if ch = "i" then
      p := 1; prdReadInt(@ai)
      if abs(ai) >= largeint then
        op := 8
        store[icp].vi := ai; q := maxstk
        while store[q].vi <> ai do inc(q) end
        if q = icp then
          inc(icp)
          if icp = overi then errorl("integer table overflow"); return end
        end
      else q := ai end

    elsif ch = "r" then
      op := 8; p := 2
      prdReadReal(@r)
      realstore[rcp] := r; q := overi
      while realstore[q] <> r do inc(q) end
      if q = rcp then
        inc(rcp)
        if rcp = overr then errorl("real table overflow"); return end
      end

    elsif ch = "n" then
      // nil: p,q = 0

    elsif ch = "b" then
      p := 3; prdReadInt(@q)

    elsif ch = "c" then
      p := 6
      // skip spaces until quote
      prdReadChar(@ch)
      while ch = " " do prdReadChar(@ch) end
      if ch <> "'" then errorl("illegal character"); return end
      prdReadChar(@ch); q := +ord(ch)
      prdReadChar(@ch)
      if ch <> "'" then errorl("illegal character"); return end

    elsif ch = "(" then
      op := 8; p := 4
      s := setEmpty()
      prdReadChar(@ch)
      while ch <> ")" do
        prdReadInt(@s1)
        s := setAdd(s, s1)
        prdReadChar(@ch)
      end
      storeSetPut(scp, s); q := overr
      while not setEq(storeSetGet(q), s) do inc(q) end
      if q = scp then
        inc(scp)
        if scp = overs then errorl("set table overflow"); return end
      end
    end

  elsif op = 26 then
    // chk
    typesymbol()
    prdReadInt(@lb); prdReadInt(@ub)
    if op = 95 then q := lb
    else
      store[bcp - 1].vi := lb; store[bcp].vi := ub
      q := overs
      while not ((store[q - 1].vi = lb) and (store[q].vi = ub)) do q := q + 2 end
      if q = bcp then
        bcp := bcp + 2
        if bcp = overb then errorl("boundary table overflow"); return end
      end
    end

  elsif op = 56 then
    // lca
    if mcp + 16 >= overm then errorl("multiple table overflow"); return end
    mcp := mcp + strglgth
    q := mcp
    for ai := 0 to strglgth - 1 do
      prdReadChar(@ch)
      store[q + ai].vi := +ord(ch)  // store as char ordinal in vi
    end

  elsif op = 6 then
    // sto
    typesymbol()

  elsif (op >= 27) and (op <= 54) then
    // adi..dvr: no parameters

  elsif op = 58 then
    // stp: no parameters

  elsif (op = 59) or (op = 60) then
    // ord, chr: skip store
    skipStore := true

  elsif op = 61 then
    // ujc: no parameters
  end

  if errorFlag then return end

  if not skipStore then
    // store instruction
    if (pc mod 2) <> 0 then
      code[pc div 2].op2 := op
      code[pc div 2].p2 := p
      code[pc div 2].q2 := q
    else
      code[pc div 2].op1 := op
      code[pc div 2].p1 := p
      code[pc div 2].q1 := q
    end
    inc(pc)
  end

  prdReadLn()
end assemble

// pint.pas lines 202-221: generate
proc generate()
  var x: integer
      again: boolean
begin
  again := true
  while again and not errorFlag do
    prdReadChar(@ch)  // first character of line
    if ch = "i" then
      prdReadLn()
    elsif ch = "l" then
      prdReadInt(@x)
      if not prdIsEoln() then prdReadChar(@ch) end
      if ch = "=" then prdReadInt(@labelvalue)
      else labelvalue := pc end
      update(x)
      prdReadLn()
    elsif ch = "q" then
      again := false
      prdReadLn()
    elsif ch = " " then
      prdReadChar(@ch)
      assemble()
    else
      prdReadLn()  // skip unknown lines
    end
  end
end generate

