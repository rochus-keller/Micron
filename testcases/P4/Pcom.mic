    chartp[ord(",")] := T.special; chartp[ord(".")] := T.chperiod; chartp[ord("'")] := T.chstrquo
    chartp[ord("[")] := T.special; chartp[ord("]")] := T.special; chartp[ord(":")] := T.chcolon
