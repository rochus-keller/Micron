// pcom.pas lines 1440-1481: typedeclaration
proc typedeclaration(fsys: T.SetOfSys)
  var lcp, lcp1, lcp2: T.Ctp; lsp: T.Stp; lsize: integer
begin
  if sy <> T.ident then error(2); skip(T.ssAdd(fsys, T.ident)) end
  while sy = T.ident do
    new(lcp)
    lcp.name := id; lcp.idtype := nil; lcp.klass := T.types
    insymbol()
    if (sy = T.relop) and (op = T.eqop) then insymbol() else error(16) end
    typ(T.ssAdd(fsys, T.semicolon), @lsp, @lsize)
    enterid(lcp)
    lcp.idtype := lsp
    // resolve forward references
    lcp1 := fwptr
    while lcp1 <> nil do
      if lcp1.name = lcp.name then // alphaEq(@lcp1.name, @lcp.name)
        lcp1.idtype.eltype := lcp.idtype
        if lcp1 <> fwptr then lcp2.next := lcp1.next
        else fwptr := lcp1.next end
      else lcp2 := lcp1 end
      lcp1 := lcp1.next
    end
    if sy = T.semicolon then
      insymbol()
      if not T.symIn(T.ssAdd(fsys, T.ident), sy) then
        error(6); skip(T.ssAdd(fsys, T.ident))
      end
    else error(14) end
  end
  if fwptr <> nil then
    error(117); O.Ln
    while fwptr <> nil do
      O.String(" type-id "); printAlpha(fwptr.name); O.Ln
      fwptr := fwptr.next
    end
  end
end typedeclaration


// pcom.pas lines 1483-1519: vardeclaration
proc vardeclaration(fsys: T.SetOfSys)
  var lcp, nxt: T.Ctp; lsp: T.Stp; lsize: integer
begin
  nxt := nil
