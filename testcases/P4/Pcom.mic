// Main entry point
// pcom.pas lines 3978-4000
begin
  // Initialize
  hasLookAhead := false
  initscalars()
  initsets()
  inittables()

  // Enter standard names and standard types
  level := 0; top := 0
  display[0].fname := nil; display[0].flabel := nil; display[0].occur := T.blck
  enterstdtypes()
  stdnames()
  entstdnames()
  enterundecl()
  top := 1; level := 1
  display[1].fname := nil; display[1].flabel := nil; display[1].occur := T.blck

  // Open source file and output file, then compile
  if A.Count() < 2 then
    println("Usage: Pcom <source.pas>")
    return
  end
  argptr := A.Arg(1)
  if argptr = nil then
    println("Error: cannot read argument")
    return
  end
  // Copy arg to srcname (up to 255 chars)
  argidx := 0
  while (argidx < 255) and (argptr[argidx] <> 0X) do
    srcname[argidx] := argptr[argidx]; inc(argidx)
  end
  srcname[argidx] := 0X
  srcfile := F.Open(@srcname, F.ReadOnly)
  if srcfile = nil then
    print("Error: cannot open "); println(srcname)
    return
  end
  prrname := "prr"
  prr := F.Open(@prrname, F.Create)
  insymbol()
  programme(T.ssDiff(T.ssUnion(blockbegsys, statbegsys), T.symBit(T.casesy)))
  F.Close(prr)
end Pcom
