          top := top + 1; lcnt1 := lcnt1 + 1
          display[top].fname := gattr.typtr.fstfld
          display[top].flabel := nil
          if gattr.access = T.drct then
            display[top].occur := T.crec
            display[top].clev := gattr.vlevel
            display[top].cdspl := gattr.dplmt
          else
            loadaddress()
            align(nilptr, @lc)
            gen2t(56, 0, lc, nilptr)
            display[top].occur := T.vrec
            display[top].vdspl := lc
            lc := lc + T.ptrsize
            if lc > lcmax then lcmax := lc end
          end
        else error(250) end
      else error(140) end
    end
    test := sy <> T.comma
    if not test then insymbol() end
    if test then exit end
  end // loop
  if sy = T.dosy then insymbol() else error(54) end
  statement(fsys)
  top := top - lcnt1; lc := llc
end withstatement

// pcom.pas lines 3431-3467: statement
proc statement(fsys: T.SetOfSys)
  var lcp: T.Ctp; llp: T.Lbp
begin
  if level <= 1 then
  end
  // Check for label
  if sy = T.intconst then
    llp := display[level].flabel
    while llp <> nil do
      if llp.labval = val.ival then
        if llp.defined then error(165) end
        putlabel(llp.labname); llp.defined := true
        llp := nil // break
      else llp := llp.nextlab end
    end
    // If we didn't find the label in the loop above, error
    insymbol()
    if sy = T.colon then insymbol() else error(5) end
  end
  if not T.symIn(T.ssAdd(fsys, T.ident), sy) then
    error(6); skip(fsys)
  end
  if T.symIn(T.ssAdd(statbegsys, T.ident), sy) then
    if sy = T.ident then
      searchid(T.idSet5(T.vars, T.field, T.funcc, T.procc, T.procc), @lcp)
      insymbol()
      if lcp.klass = T.procc then
        call(fsys, lcp)
      else assignment(fsys, lcp) end
    elsif sy = T.beginsy then insymbol(); compoundstatement(fsys)
    elsif sy = T.gotosy then insymbol(); gotostatement(fsys)
    elsif sy = T.ifsy then insymbol(); ifstatement(fsys)
    elsif sy = T.casesy then insymbol(); casestatement(fsys)
    elsif sy = T.whilesy then insymbol(); whilestatement(fsys)
    elsif sy = T.repeatsy then insymbol(); repeatstatement(fsys)
    elsif sy = T.forsy then insymbol(); forstatement(fsys)
    elsif sy = T.withsy then insymbol(); withstatement(fsys)
    end
    if not ((sy = T.semicolon) or (sy = T.endsy) or (sy = T.elsesy) or (sy = T.untilsy)) then
      error(6); skip(fsys)
    end
  end
end statement

// pcom.pas lines 3469-3564: body - generates code for a block's body
proc body(fsys: T.SetOfSys; fprocp_: T.Ctp)
  var entname, segsize, stacktop: integer
      llc1: integer; lcp: T.Ctp; llp: T.Lbp; llcp: T.Ctp
      saveid: T.Alpha
begin
  if fprocp_ <> nil then entname := fprocp_.pfname
  else genlabel(@entname) end
  fprocp := fprocp_  // set module-level fprocp for use by variable()
  cstptrix := 0; cstoccmax := 65; bCixmax := 1000
  topnew := T.lcaftermarkstack; topmax := T.lcaftermarkstack
  putlabel(entname); genlabel(@segsize); genlabel(@stacktop)
  gencupent(32, 1, segsize); gencupent(32, 2, stacktop)
  if fprocp_ <> nil then
    // Copy multiple values into local cells
    llc1 := T.lcaftermarkstack
    lcp := fprocp_.next
    while lcp <> nil do
      align(parmptr, @llc1)
      if lcp.klass = T.vars then
        if lcp.idtype <> nil then
          if ord(lcp.idtype.form) > ord(T.power) then
            if lcp.vkind = T.actual then
              gen2(50, 0, lcp.vaddr)
              gen2t(54, 0, llc1, nilptr)
              gen1(40, lcp.idtype.size)
            end
            llc1 := llc1 + T.ptrsize
          else llc1 := llc1 + lcp.idtype.size end
        end
      end
      lcp := lcp.next
    end
  end
  lcmax := lc
  // Parse statements
  loop
    loop
      statement(T.ssAdd(T.ssAdd(fsys, T.semicolon), T.endsy))
      if not T.symIn(statbegsys, sy) then exit end
    end
    test := sy <> T.semicolon
    if not test then
      insymbol()
    end
    if test then exit end
  end
  if sy = T.endsy then insymbol() else error(13) end
  // Check for undefined labels
  llp := display[top].flabel
  while llp <> nil do
    if not llp.defined then
      error(168)
      PRINTLN
      print(" label "); print(llp.labval)
    end
    llp := llp.nextlab
  end
  if fprocp_ <> nil then
    if fprocp_.idtype = nil then gen1(42, +ord("p"))
    else gen0t(42, fprocp_.idtype) end
    align(parmptr, @lcmax)
    if prcode then
      fWriteString(prr, "l"); fWriteInt(prr, segsize, 4)
      fWriteString(prr, "="); fWriteInt(prr, lcmax, 1); fWriteLn(prr)
      fWriteString(prr, "l"); fWriteInt(prr, stacktop, 4)
      fWriteString(prr, "="); fWriteInt(prr, topmax, 1); fWriteLn(prr)
    end
  else
    gen1(42, +ord("p"))
    align(parmptr, @lcmax)
    if prcode then
      fWriteString(prr, "l"); fWriteInt(prr, segsize, 4)
      fWriteString(prr, "="); fWriteInt(prr, lcmax, 1); fWriteLn(prr)
      fWriteString(prr, "l"); fWriteInt(prr, stacktop, 4)
      fWriteString(prr, "="); fWriteInt(prr, topmax, 1); fWriteLn(prr)
      fWriteString(prr, "q"); fWriteLn(prr)
    end
    ic := 0
    // Generate call of main program at absolute address zero
    gen1(41, 0); gencupent(46, 0, entname); gen0(29)
    if prcode then
      fWriteString(prr, "q"); fWriteLn(prr)
    end
    saveid := id
    while fextfilep <> nil do
      if not ((fextfilep.filename = "input   ")
              or (fextfilep.filename = "output  ")
              or (fextfilep.filename = "prd     ")
              or (fextfilep.filename = "prr     ")) then
        id := fextfilep.filename
        searchid(T.idSet2(T.vars, T.vars), @llcp)
        if llcp.idtype <> nil then
          if llcp.idtype.form <> T.files then
            PRINTLN; print("        undeclared external file")
            print(fextfilep.filename)
          end
        end
      end
      fextfilep := fextfilep.nextfile
    end
    id := saveid
    if prtables then
      PRINTLN; printtables(true)
    end
  end
end body


// pcom.pas lines 3566-3588: block
proc block(fsys: T.SetOfSys; fsy: T.Symbol; fprocp_: T.Ctp)
  var lsy: T.Symbol
begin
  dp := true
  loop
    if sy = T.labelsy then insymbol(); labeldeclaration(fsys) end
    if sy = T.constsy then insymbol(); constdeclaration(fsys) end
    if sy = T.typesy then insymbol(); typedeclaration(fsys) end
    if sy = T.varsy then insymbol(); vardeclaration(fsys) end
    while (sy = T.procsy) or (sy = T.funcsy) do
      lsy := sy; insymbol(); procdeclaration(fsys, lsy)
    end
    if sy <> T.beginsy then
      error(18); skip(fsys)
    end
    if T.symIn(statbegsys, sy) or F.Eof(srcfile) then exit end
  end
  dp := false
  if sy = T.beginsy then insymbol() else error(17) end
  loop
    body(T.ssAdd(fsys, T.casesy), fprocp_)
    if sy <> fsy then
      error(6); skip(fsys)
    end
    if (sy = fsy) or T.symIn(blockbegsys, sy) or F.Eof(srcfile) then exit end
  end
end block


// pcom.pas lines 3590-3621: programme
proc programme(fsys: T.SetOfSys)
  var extfp: T.ExtFileP
begin
  if sy = T.progsy then
    insymbol()
    if sy <> T.ident then error(2) end
    insymbol()
    if not ((sy = T.lparent) or (sy = T.semicolon)) then error(14) end
    if sy = T.lparent then
      loop
        insymbol()
        if sy = T.ident then
          new(extfp)
          extfp.filename := id; extfp.nextfile := fextfilep
          fextfilep := extfp
          insymbol()
          if not ((sy = T.comma) or (sy = T.rparent)) then error(20) end
        else error(2) end
        if sy <> T.comma then exit end
      end
      if sy <> T.rparent then error(4) end
      insymbol()
    end
    if sy <> T.semicolon then error(14) else insymbol() end
  end
  loop
    block(fsys, T.period, nil)
    if sy <> T.period then error(21) end
    if (sy = T.period) or F.Eof(srcfile) then exit end
  end
  if list then PRINTLN end
  if errinx <> 0 then
    list := false; endofline()
  end
end programme

