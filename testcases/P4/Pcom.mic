// File I/O helper procedures
proc fWriteString(f: F.File; const s: pointer to array of char)
  var i: integer; dummy: boolean
begin
  i := 0
  while s[i] <> 0X do
    dummy := F.Write(f, ord(s[i])); inc(i)
  end
end fWriteString

// The Files module API differs from Pascal's; these helpers bridge the gap.

proc fWriteChar(f: F.File; c: char)
  var dummy: boolean
begin
  dummy := F.Write(f, ord(c))
end fWriteChar

proc fWriteLn(f: F.File)
  var dummy: boolean
begin
  dummy := F.Write(f, 0AH)
end fWriteLn

proc fWriteInt(f: F.File; v: integer; w: integer)
  // Write integer v right-justified in field of width w
  var buf: array 20 of char; i, n, neg: integer; d: integer
begin
  neg := 0
  n := v
  if n < 0 then neg := 1; n := -n end
  i := 0
  if n = 0 then buf[0] := "0"; i := 1
  else
    while n > 0 do
      d := n mod 10; buf[i] := chr(+ord("0") + d); inc(i); n := n div 10
    end
  end
  // pad with spaces
  while i + neg < w do fWriteChar(f, " "); dec(w) end
  if neg = 1 then fWriteChar(f, "-") end
  while i > 0 do dec(i); fWriteChar(f, buf[i]) end
end fWriteInt

proc fWriteArr4(f: F.File; const a: array 5 of char)
  var i: integer
begin
  for i := 0 to 3 do
    fWriteChar(f, a[i])
  end
end fWriteArr4

proc printAlpha(const a: T.Alpha)
  var i: integer
begin
  for i := 0 to T.alfalength - 1 do
    if a[i] <> 0X then O.Char(a[i]) end
  end
end printAlpha

// MIC interpreter had issue on direct array comparison (a = b, a < b).
(* obsolete
proc alphaEq(x, y: ^T.Alpha): boolean
  var i: integer
begin
  i := 0
  while i < T.alfalength do
    if x[i] <> y[i] then return false end
    inc(i)
  end
  return true
end alphaEq 

proc alphaLt(x, y: ^T.Alpha): boolean
  var i: integer
begin
  i := 0
  while (i < T.alfalength) and (x[i] = y[i]) do inc(i) end
  if i = T.alfalength then return false end
  return x[i] < y[i]
end alphaLt *)


// pcom.pas lines 303-336: endofline
proc endofline()
  var lastpos, freepos, currpos, currnmr, f, k: integer
begin
  if errinx > 0 then
    O.Int(linecount, 6); O.String(" ****  ")
    lastpos := 0; freepos := 1
    for k := 0 to errinx - 1 do
      currpos := errlist[k].pos; currnmr := errlist[k].nmr
      if currpos = lastpos then O.Char(",")
      else
        while freepos < currpos do O.Char(" "); inc(freepos) end
        O.Char("^")
        lastpos := currpos
      end
      if currnmr < 10 then f := 1
      elsif currnmr < 100 then f := 2
      else f := 3 end
      O.Int(currnmr, f)
      freepos := freepos + f + 1
    end
    O.Ln; errinx := 0
  end
  inc(linecount)
  if list then
    O.Int(linecount, 6); O.String("  ")
    if dp then O.Int(lc, 7) else O.Int(ic, 7) end
    O.Char(" ")
  end
  chcnt := 0
end endofline

// pcom.pas lines 338-347: error
proc error(ferrnr: integer)
begin
  if errinx >= 9 then
    errlist[9].nmr := 255; errinx := 10
  else
    errlist[errinx].nmr := ferrnr
    inc(errinx)
  end
  if errinx > 0 then
    errlist[errinx - 1].pos := chcnt
  end
end error


// Forward declarations for mutually recursive procedures
procedure^ insymbol()
procedure^ block(fsys: T.SetOfSys; fsy: T.Symbol; fprocp_: T.Ctp)


// pcom.pas lines 358-371: nextch - read next character from input
proc nextch()
  var b: byte
begin
  if eol then
    if list then O.Ln end
    endofline()
  end
  if hasLookAhead then
    hasLookAhead := false
    ch := lookAheadCh
    if ch = 0AX then eol := true else eol := false end
    if list then O.Char(ch) end
    inc(chcnt)
  elsif not F.Eof(srcfile) then
    eol := false
    if F.Read(srcfile, @b) then
      ch := chr(b)
      if ch = 0AX then eol := true end
      if list then O.Char(ch) end
      inc(chcnt)
    else
      eol := true
    end
  else
    O.String("   *** eof encountered"); O.Ln
    test := false
  end
end nextch

// peekNextCh - peek at next char without consuming it
proc peekNextCh(): char
  var b: byte
begin
  if hasLookAhead then return lookAheadCh end
  if not F.Eof(srcfile) then
    if F.Read(srcfile, @b) then
      lookAheadCh := chr(b)
      hasLookAhead := true
      return lookAheadCh
    end
  end
  return " "
end peekNextCh

// pcom.pas lines 373-394: options
proc options()
begin
  loop
    nextch()
    if ch <> "*" then
      if ch = "t" then
        nextch(); prtables := (ch = "+")
      elsif ch = "l" then
        nextch(); list := (ch = "+")
        if not list then O.Ln end
      elsif ch = "d" then
        nextch(); debug := (ch = "+")
      elsif ch = "c" then
        nextch(); prcode := (ch = "+")
      end
      nextch()
    end
    if ch <> "," then return end
  end
end options

// pcom.pas lines 396-549: insymbol main body
proc insymbol()
  var i, k: integer
      digit: array T.strglgth of char
      string_: array T.strglgth of char
      lvp: T.Csp
begin
  restart:
  // skip blanks and newlines
  loop
    while ((ch = " ") or (ch = 9X)) and not eol do nextch() end
    test := eol
    if test then
      if F.Eof(srcfile) then
        sy := T.period  // treat as end
        return
      end
      nextch()
    end
    if not test then goto done_skip end
  end
  done_skip:

  if chartp[ord(ch)] = T.illegal then
    sy := T.othersy; op := T.noop
    error(399); nextch()
    return
  end

  // pcom.pas lines 407-548: case chartp[ch]
  if chartp[ord(ch)] = T.letter then
    // pcom.pas lines 409-424: identifier or reserved word
    k := 0
    loop
      if k < 8 then id[k] := ch; inc(k) end
      nextch()
      if (chartp[ord(ch)] = T.special) or (chartp[ord(ch)] = T.illegal)
         or (chartp[ord(ch)] = T.chstrquo) or (chartp[ord(ch)] = T.chcolon)
         or (chartp[ord(ch)] = T.chperiod) or (chartp[ord(ch)] = T.chlt)
         or (chartp[ord(ch)] = T.chgt) or (chartp[ord(ch)] = T.chlparen)
         or (chartp[ord(ch)] = T.chspace) then
        goto id_done
      end
    end
    id_done:
    if k >= kk then kk := k
    else
      while kk > k do dec(kk); id[kk] := " " end
    end
    // search reserved words
    i := frw[k]
    while i < frw[k + 1] do
      if rw[i] = id then // alphaEq(@rw[i], @id)
        sy := rsy[i]; op := rop[i]; return
      end
      inc(i)
    end
    sy := T.ident; op := T.noop

  elsif chartp[ord(ch)] = T.number then
    // pcom.pas lines 425-480: number
    op := T.noop; i := 0
    loop
      inc(i); if i <= digmax then digit[i - 1] := ch end
      nextch()
      if chartp[ord(ch)] <> T.number then goto num_done end
    end
    num_done:
    if ((ch = ".") and (peekNextCh() <> "."))
       or (ch = "e") then
      // real constant
      k := i
      if ch = "." then
        inc(k); if k <= digmax then digit[k - 1] := ch end
        nextch()
        if chartp[ord(ch)] <> T.number then error(201)
        else
          loop
            inc(k); if k <= digmax then digit[k - 1] := ch end
            nextch()
            if chartp[ord(ch)] <> T.number then goto real_frac_done end
          end
          real_frac_done:
        end
      end
      if ch = "e" then
        inc(k); if k <= digmax then digit[k - 1] := ch end
        nextch()
        if (ch = "+") or (ch = "-") then
          inc(k); if k <= digmax then digit[k - 1] := ch end
          nextch()
        end
        if chartp[ord(ch)] <> T.number then error(201)
        else
          loop
            inc(k); if k <= digmax then digit[k - 1] := ch end
            nextch()
            if chartp[ord(ch)] <> T.number then goto real_exp_done end
          end
          real_exp_done:
        end
      end
      new(lvp); sy := T.realconst; lvp.cclass := T.reel
      for i := 0 to T.strglgth - 1 do lvp.rval[i] := " " end
      if k <= digmax then
        for i := 1 to k do lvp.rval[i] := digit[i - 1] end
      else
        error(203)
        lvp.rval[1] := "0"; lvp.rval[2] := "."
        lvp.rval[3] := "0"
      end
      val.intval := false; val.valp := lvp
    else
      // integer constant
      if i > digmax then error(203); val.ival := 0
      else
        val.ival := 0
        for k := 0 to i - 1 do
          if val.ival <= mxint10 then
            val.ival := val.ival * 10 + ordint[ord(digit[k])]
          else error(203); val.ival := 0 end
        end
        sy := T.intconst
      end
      val.intval := true
    end

  elsif chartp[ord(ch)] = T.chstrquo then
    // pcom.pas lines 481-502: string constant
    lgth := 0; sy := T.stringconst; op := T.noop
    loop
      loop
        nextch(); inc(lgth)
        if lgth <= T.strglgth then string_[lgth - 1] := ch end
        if eol or (ch = "'") then goto str_inner_done end
      end
      str_inner_done:
      if eol then error(202) else nextch() end
      if ch <> "'" then goto str_done end
    end
    str_done:
    dec(lgth)  // now lgth = nr of chars in string
    if lgth = 0 then error(205)
    elsif lgth = 1 then val.intval := true; val.ival := +ord(string_[0])
    else
      new(lvp); lvp.cclass := T.strg
      if lgth > T.strglgth then error(399); lgth := T.strglgth end
      lvp.slgth := lgth
      for i := 0 to lgth - 1 do lvp.sval[i] := string_[i] end
      val.intval := false; val.valp := lvp
    end

  elsif chartp[ord(ch)] = T.chcolon then
    // pcom.pas lines 503-508
    op := T.noop; nextch()
    if ch = "=" then sy := T.becomes; nextch()
    else sy := T.colon end

  elsif chartp[ord(ch)] = T.chperiod then
    // pcom.pas lines 509-514
    op := T.noop; nextch()
    if ch = "." then sy := T.colon; nextch()
    else sy := T.period end

  elsif chartp[ord(ch)] = T.chlt then
    // pcom.pas lines 515-523
    nextch(); sy := T.relop
    if ch = "=" then op := T.leop; nextch()
    elsif ch = ">" then op := T.neop; nextch()
    else op := T.ltop end

  elsif chartp[ord(ch)] = T.chgt then
    // pcom.pas lines 524-529
    nextch(); sy := T.relop
    if ch = "=" then op := T.geop; nextch()
    else op := T.gtop end

  elsif chartp[ord(ch)] = T.chlparen then
    // pcom.pas lines 530-542: comment or left paren
    nextch()
    if ch = "*" then
      nextch()
      if ch = "$" then options() end
      loop
        while (ch <> "*") and not F.Eof(srcfile) do nextch() end
        nextch()
        if (ch = ")") or F.Eof(srcfile) then goto comment_done end
      end
      comment_done:
      nextch(); goto restart
    end
    sy := T.lparent; op := T.noop

  elsif chartp[ord(ch)] = T.special then
    // pcom.pas lines 543-546
    sy := ssy[ord(ch)]; op := sop[ord(ch)]
    nextch()

  elsif chartp[ord(ch)] = T.chspace then
    sy := T.othersy
  end
end insymbol


// pcom.pas lines 551-573: enterid - enter identifier into name table
proc enterid(fcp: T.Ctp)
  var nam: T.Alpha; lcp, lcp1: T.Ctp; lleft: boolean
begin
  nam := fcp.name
  lcp := display[top].fname
  if lcp = nil then
    display[top].fname := fcp
  else
    loop
      lcp1 := lcp
      if lcp.name = nam then // alphaEq(@lcp.name, @nam)
        error(101); lcp := lcp.rlink; lleft := false
      elsif lcp.name < nam then // alphaLt(@lcp.name, @nam)
        lcp := lcp.rlink; lleft := false
      else
        lcp := lcp.llink; lleft := true
      end
      if lcp = nil then goto enterid_done end
    end
    enterid_done:
    if lleft then lcp1.llink := fcp
    else lcp1.rlink := fcp end
  end
  fcp.llink := nil; fcp.rlink := nil
end enterid

// pcom.pas lines 575-586: searchsection
proc searchsection(fcp: T.Ctp; fcp1: ^T.Ctp)
begin
  while fcp <> nil do
    if fcp.name = id then fcp1^ := fcp; return end // alphaEq(@fcp.name, @id)
    if fcp.name < id then fcp := fcp.rlink // alphaLt(@fcp.name, @id)
    else fcp := fcp.llink end
  end
  fcp1^ := nil
end searchsection

// pcom.pas lines 588-626: searchid
proc searchid(fidcls: T.SetOfIds; fcp: ^T.Ctp)
  var lcp: T.Ctp
begin
  disx := top
  while disx >= 0 do
    lcp := display[disx].fname
    while lcp <> nil do
      if lcp.name = id then // alphaEq(@lcp.name, @id)
        if T.idIn(fidcls, lcp.klass) then fcp^ := lcp; return end
        if prterr then error(103) end
        lcp := lcp.rlink
      elsif lcp.name < id then lcp := lcp.rlink // alphaLt(@lcp.name, @id)
      else lcp := lcp.llink end
    end
    dec(disx)
  end
  // search not successful
  if prterr then
    error(104)
    if T.idIn(fidcls, T.types) then lcp := utypptr
    elsif T.idIn(fidcls, T.vars) then lcp := uvarptr
    elsif T.idIn(fidcls, T.field) then lcp := ufldptr
    elsif T.idIn(fidcls, T.konst) then lcp := ucstptr
    elsif T.idIn(fidcls, T.procc) then lcp := uprcptr
    else lcp := ufctptr end
  end
  fcp^ := lcp
end searchid

// pcom.pas lines 628-644: getbounds
proc getbounds(fsp: T.Stp; fmin, fmax: ^integer)
begin
  fmin^ := 0; fmax^ := 0
  if fsp <> nil then
    if fsp.form = T.subrange then
      fmin^ := fsp.min.ival; fmax^ := fsp.max.ival
    elsif fsp = charptr then
      fmin^ := T.ordminchar; fmax^ := T.ordmaxchar
    elsif fsp.form = T.scalar then
      if fsp.fconst <> nil then
        fmax^ := fsp.fconst.values.ival
      end
    end
  end
end getbounds

// pcom.pas lines 646-666: alignquot
proc alignquot(fsp: T.Stp): integer
begin
  if fsp = nil then return 1 end
  if fsp.form = T.scalar then
    if fsp = intptr then return T.intal
    elsif fsp = boolptr then return T.boolal
    elsif fsp.scalkind = T.declared then return T.intal
    elsif fsp = charptr then return T.charal
    elsif fsp = realptr then return T.realal
    else return T.parmal end
  elsif fsp.form = T.subrange then return alignquot(fsp.rangetype)
  elsif fsp.form = T.pointer_f then return T.adral
  elsif fsp.form = T.power then return T.setal
  elsif fsp.form = T.files then return T.fileal
  elsif fsp.form = T.arrays then return alignquot(fsp.aeltype)
  elsif fsp.form = T.records then return T.recal
  elsif (fsp.form = T.variant_f) or (fsp.form = T.tagfld) then error(501); return 1
  else return 1 end
end alignquot

// pcom.pas lines 668-674: align
proc align(fsp: T.Stp; flc: ^integer)
  var k, l: integer
begin
  k := alignquot(fsp)
  l := flc^ - 1
  flc^ := l + k - (k + l) mod k
end align


// pcom.pas lines 676-845: printtables (simplified for Micron)
proc printtables(fb: boolean)
  var i, lim: integer
  // Forward declarations for mutually recursive procs
  procedure^ markstp(fp: T.Stp)
  procedure^ markctp(fp: T.Ctp)
  procedure^ followstp(fp: T.Stp)
  procedure^ followctp(fp: T.Ctp)

  proc markstp(fp: T.Stp)
  begin
    if fp <> nil then
      fp.marked := true
      if fp.form = T.scalar then // nothing
      elsif fp.form = T.subrange then markstp(fp.rangetype)
      elsif fp.form = T.pointer_f then // don't mark eltype (cycle)
      elsif fp.form = T.power then markstp(fp.elset)
      elsif fp.form = T.arrays then
        markstp(fp.aeltype); markstp(fp.inxtype)
      elsif fp.form = T.records then
        markctp(fp.fstfld); markstp(fp.recvar)
      elsif fp.form = T.files then markstp(fp.filtype)
      elsif fp.form = T.tagfld then markstp(fp.fstvar)
      elsif fp.form = T.variant_f then
        markstp(fp.nxtvar); markstp(fp.subvar)
      end
    end
  end markstp

  proc markctp(fp: T.Ctp)
  begin
    if fp <> nil then
      markctp(fp.llink); markctp(fp.rlink)
      markstp(fp.idtype)
    end
  end markctp

  proc followstp(fp: T.Stp)
  begin
    if fp <> nil then
      if fp.marked then
        fp.marked := false
        O.String("    "); O.Int(0, 6); O.Int(fp.size, 10)
        if fp.form = T.scalar then
          O.String("    scalar")
          if fp.scalkind = T.standard then O.String("  standard")
          else O.String("  declared") end
          O.Ln
        elsif fp.form = T.subrange then
          O.String("  subrange"); O.Ln
          followstp(fp.rangetype)
        elsif fp.form = T.pointer_f then
          O.String("   pointer"); O.Ln
        elsif fp.form = T.power then
          O.String("       set"); O.Ln
          followstp(fp.elset)
        elsif fp.form = T.arrays then
          O.String("     array"); O.Ln
          followstp(fp.aeltype); followstp(fp.inxtype)
        elsif fp.form = T.records then
          O.String("    record"); O.Ln
          followctp(fp.fstfld); followstp(fp.recvar)
        elsif fp.form = T.files then
          O.String("      file"); O.Ln
          followstp(fp.filtype)
        elsif fp.form = T.tagfld then
          O.String("    tagfld"); O.Ln
          followstp(fp.fstvar)
        elsif fp.form = T.variant_f then
          O.String("   variant"); O.Ln
          followstp(fp.nxtvar); followstp(fp.subvar)
        end
      end
    end
  end followstp

  proc followctp(fp: T.Ctp)
  begin
    if fp <> nil then
      O.String("    "); printAlpha(fp.name)
      if fp.klass = T.types then O.String("      type")
      elsif fp.klass = T.konst then O.String("  constant")
      elsif fp.klass = T.vars then
        O.String("  variable")
        if fp.vkind = T.actual then O.String("    actual")
        else O.String("    formal") end
      elsif fp.klass = T.field then O.String("     field")
      elsif fp.klass = T.procc then O.String(" procedure")
      elsif fp.klass = T.funcc then O.String("  function")
      end
      O.Ln
      followctp(fp.llink); followctp(fp.rlink)
      followstp(fp.idtype)
    end
  end followctp

begin
  // printtables main body
  O.Ln; O.Ln; O.Ln
  if fb then lim := 0
  else lim := top; O.String(" local") end
  O.String(" tables "); O.Ln; O.Ln
  // marker
  for i := top to 0 by -1 do markctp(display[i].fname) end
  // follow
  for i := top to 0 by -1 do followctp(display[i].fname) end
  O.Ln
end printtables

