// pcom.pas lines 1825-1828: mes - track stack usage
proc mes(i: integer)
begin
  topnew := topnew + cdx[i] * T.maxstack
  if topnew > topmax then topmax := topnew end
end mes

// pcom.pas lines 1830-1831: putic
proc putic()
begin
  if ic mod 10 = 0 then
    fWriteString(prr, "i"); fWriteInt(prr, ic, 5); fWriteLn(prr)
  end
end putic

// pcom.pas lines 1833-1837: gen0
proc gen0(fop: integer)
begin
  if prcode then putic(); fWriteArr4(prr, mn[fop]); fWriteLn(prr) end
  ic := ic + 1; mes(fop)
end gen0

// pcom.pas lines 1839-1866: gen1
proc gen1(fop: integer; fp2: integer)
  var k: integer
begin
  if prcode then
    putic(); fWriteArr4(prr, mn[fop])
    if fop = 30 then
      // csp - original: writeln(prr,sna[fp2]:12)
      fWriteString(prr, "        "); fWriteArr4(prr, sna[fp2]); fWriteLn(prr)
      topnew := topnew + pdx[fp2] * T.maxstack
      if topnew > topmax then topmax := topnew end
    else
      if fop = 38 then
        // lca - string constant
        fWriteChar(prr, "'")
        k := 0
        while k < cstptr[fp2].slgth do
          fWriteChar(prr, cstptr[fp2].sval[k])
          inc(k)
        end
        while k < T.strglgth do fWriteChar(prr, " "); inc(k) end
        fWriteChar(prr, "'"); fWriteLn(prr)
      elsif fop = 42 then
        // ret
        fWriteChar(prr, chr(fp2)); fWriteLn(prr)
      else
        fWriteInt(prr, fp2, 12); fWriteLn(prr)
      end
      mes(fop)
    end
  end
  ic := ic + 1
end gen1

// pcom.pas lines 1868-1902: gen2
proc gen2(fop: integer; fp1, fp2: integer)
  var k: integer
begin
  if prcode then
    putic(); fWriteArr4(prr, mn[fop])
    if (fop = 45) or (fop = 50) or (fop = 54) or (fop = 56) then
      // chk, lda, lod, str
      fWriteChar(prr, " "); fWriteInt(prr, fp1, 3); fWriteInt(prr, fp2, 8)
      fWriteLn(prr)
    elsif (fop = 47) or (fop = 48) or (fop = 49) or (fop = 52) or (fop = 53) or (fop = 55) then
      // equ, geq, grt, leq, les, neq
      fWriteChar(prr, chr(fp1))
      if fp1 = +ord("m") then fWriteInt(prr, fp2, 11) end
      fWriteLn(prr)
    elsif fop = 51 then
      // ldc
      if fp1 = 1 then
        fWriteString(prr, "i "); fWriteInt(prr, fp2, 1); fWriteLn(prr)
      elsif fp1 = 2 then
        fWriteString(prr, "r ")
        for k := 1 to T.strglgth do
          fWriteChar(prr, cstptr[fp2].rval[k])
        end
        fWriteLn(prr)
      elsif fp1 = 3 then
        fWriteString(prr, "b "); fWriteInt(prr, fp2, 1); fWriteLn(prr)
      elsif fp1 = 4 then
        fWriteString(prr, "n"); fWriteLn(prr)
      elsif fp1 = 6 then
