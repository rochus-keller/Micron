      lc := lc + lsize; nxt := nxt.next
    end
    if sy = T.semicolon then
      insymbol()
      if not T.symIn(T.ssAdd(fsys, T.ident), sy) then
        error(6); skip(T.ssAdd(fsys, T.ident))
