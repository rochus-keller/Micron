  ufldptr.fldaddr := 0; ufldptr.klass := T.field

  new(uprcptr)
  uprcptr.name := "        "; uprcptr.idtype := nil; uprcptr.forwdecl := false
  uprcptr.next := nil; uprcptr.externl := false; uprcptr.pflev := 0
  genlabel(@uprcptr.pfname)
  uprcptr.klass := T.procc; uprcptr.pfdeckind := T.declared; uprcptr.pfkind := T.actual

  new(ufctptr)
  ufctptr.name := "        "; ufctptr.idtype := nil; ufctptr.next := nil
  ufctptr.forwdecl := false; ufctptr.externl := false; ufctptr.pflev := 0
  genlabel(@ufctptr.pfname)
