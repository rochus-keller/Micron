    rop[6] := T.orop; rop[13] := T.andop
    for i := T.ordminchar to T.ordmaxchar do sop[i] := T.noop end
    sop[ord("+")] := T.plus; sop[ord("-")] := T.minus; sop[ord("*")] := T.mul; sop[ord("/")] := T.rdiv
    sop[ord("=")] := T.eqop; sop[ord("<")] := T.ltop;  sop[ord(">")] := T.gtop
  end rators

