proc stdnames()
begin
  na[ 1] := "false   "; na[ 2] := "true    "; na[ 3] := "input   "
  na[ 4] := "output  "; na[ 5] := "get     "; na[ 6] := "put     "
  na[ 7] := "reset   "; na[ 8] := "rewrite "; na[ 9] := "read    "
  na[10] := "write   "; na[11] := "pack    "; na[12] := "unpack  "
  na[13] := "new     "; na[14] := "release "; na[15] := "readln  "
  na[16] := "writeln "
  na[17] := "abs     "; na[18] := "sqr     "; na[19] := "trunc   "
  na[20] := "odd     "; na[21] := "ord     "; na[22] := "chr     "
  na[23] := "pred    "; na[24] := "succ    "; na[25] := "eof     "
  na[26] := "eoln    "
  na[27] := "sin     "; na[28] := "cos     "; na[29] := "exp     "
  na[30] := "sqrt    "; na[31] := "ln      "; na[32] := "arctan  "
  na[33] := "prd     "; na[34] := "prr     "; na[35] := "mark    "
end stdnames

// pcom.pas lines 3641-3667: enterstdtypes
proc enterstdtypes()
begin
  // integer
  new(intptr)
  intptr.size := T.intsize; intptr.form := T.scalar
  intptr.scalkind := T.standard
  // real
  new(realptr)
  realptr.size := T.realsize; realptr.form := T.scalar
  realptr.scalkind := T.standard
  // char
  new(charptr)
  charptr.size := T.charsize; charptr.form := T.scalar
  charptr.scalkind := T.standard
  // boolean
  new(boolptr)
  boolptr.size := T.boolsize; boolptr.form := T.scalar
  boolptr.scalkind := T.declared
  // nil
  new(nilptr)
  nilptr.eltype := nil; nilptr.size := T.ptrsize
  nilptr.form := T.pointer_f
  // parmptr (for alignment of parameters)
  new(parmptr)
  parmptr.size := T.parmsize; parmptr.form := T.scalar
  parmptr.scalkind := T.standard
  // text
  new(textptr)
  textptr.filtype := charptr; textptr.size := T.charsize
  textptr.form := T.files
end enterstdtypes

// pcom.pas lines 3669-3762: entstdnames
proc entstdnames()
  var cp, cp1: T.Ctp; i: integer
begin
  // integer type name
  new(cp); cp.llink := nil; cp.rlink := nil
  cp.name := "integer "; cp.idtype := intptr; cp.klass := T.types
  enterid(cp)
  if display[0].fname <> nil then
  end
  // real type name
  new(cp); cp.name := "real    "; cp.idtype := realptr; cp.klass := T.types
  enterid(cp)
  // char type name
  new(cp); cp.name := "char    "; cp.idtype := charptr; cp.klass := T.types
  enterid(cp)
  // boolean type name
  new(cp); cp.name := "boolean "; cp.idtype := boolptr; cp.klass := T.types
  enterid(cp)
  // text type name (standard Pascal predeclared type)
  new(cp); cp.name := "text    "; cp.idtype := textptr; cp.klass := T.types
  enterid(cp)

  // false, true constants
  cp1 := nil
  for i := 1 to 2 do
    new(cp)
    cp.name := na[i]; cp.idtype := boolptr
    cp.next := cp1; cp.values.ival := i - 1; cp.klass := T.konst
    enterid(cp); cp1 := cp
  end
  boolptr.fconst := cp

  // nil constant
  new(cp)
  cp.name := "nil     "; cp.idtype := nilptr
  cp.next := nil; cp.values.ival := 0; cp.klass := T.konst
  enterid(cp)

  // input, output file variables
  for i := 3 to 4 do
    new(cp)
    cp.name := na[i]; cp.idtype := textptr; cp.klass := T.vars
    cp.vkind := T.actual; cp.next := nil; cp.vlev := 1
    cp.vaddr := T.lcaftermarkstack + (i - 3) * T.charmax
    enterid(cp)
  end

  // prd, prr file variables
  for i := 33 to 34 do
    new(cp)
    cp.name := na[i]; cp.idtype := textptr; cp.klass := T.vars
    cp.vkind := T.actual; cp.next := nil; cp.vlev := 1
    cp.vaddr := T.lcaftermarkstack + (i - 31) * T.charmax
    enterid(cp)
  end

  // Standard procedures: get, put, reset, rewrite, read, write, pack, unpack, new, release, readln, writeln
  for i := 5 to 16 do
    new(cp)
    cp.name := na[i]; cp.idtype := nil
    cp.next := nil; cp.key := i - 4
    cp.klass := T.procc; cp.pfdeckind := T.standard
    enterid(cp)
  end
  // mark (standard proc, key=13)
  new(cp)
  cp.name := na[35]; cp.idtype := nil
  cp.next := nil; cp.key := 13
  cp.klass := T.procc; cp.pfdeckind := T.standard
  enterid(cp)

  // Standard functions: abs, sqr, trunc, odd, ord, chr, pred, succ, eof, eoln
  for i := 17 to 26 do
    new(cp)
    cp.name := na[i]; cp.idtype := nil
    cp.next := nil; cp.key := i - 16
    cp.klass := T.funcc; cp.pfdeckind := T.standard
    enterid(cp)
  end

  // Parameter of predeclared math functions
  new(cp)
  cp.name := "        "; cp.idtype := realptr; cp.klass := T.vars
  cp.vkind := T.actual; cp.next := nil; cp.vlev := 1; cp.vaddr := 0

  // sin, cos, exp, sqrt, ln, arctan
  for i := 27 to 32 do
    new(cp1)
    cp1.name := na[i]; cp1.idtype := realptr; cp1.next := cp
    cp1.forwdecl := false; cp1.externl := true; cp1.pflev := 0
    cp1.pfname := i - 12
    cp1.klass := T.funcc; cp1.pfdeckind := T.declared; cp1.pfkind := T.actual
    enterid(cp1)
  end
end entstdnames


// pcom.pas lines 3764-3796: enterundecl
proc enterundecl()
begin
  new(utypptr)
  utypptr.name := "        "; utypptr.idtype := nil; utypptr.klass := T.types

  new(ucstptr)
