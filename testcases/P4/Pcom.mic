    rsy[16] := T.elsesy;    rsy[17] := T.withsy;    rsy[18] := T.gotosy
    rsy[19] := T.casesy;    rsy[20] := T.typesy
    rsy[21] := T.filesy;    rsy[22] := T.beginsy
