      if sy = T.ident then
        new(lcp)
        lcp.name := id; lcp.next := nxt; lcp.klass := T.vars
        lcp.idtype := nil; lcp.vkind := T.actual; lcp.vlev := level
        enterid(lcp); nxt := lcp; insymbol()
      else error(2) end
      if not T.symIn(T.ssUnion(T.ssAdd(T.ssAdd(fsys, T.comma), T.colon), typedels), sy) then
        error(6); skip(T.ssUnion(T.ssAdd(T.ssAdd(T.ssAdd(fsys, T.comma), T.colon), T.semicolon), typedels))
      end
      if sy <> T.comma then goto vardecl_inner_done end
      insymbol()
    end
    vardecl_inner_done:
    if sy = T.colon then insymbol() else error(5) end
    typ(T.ssUnion(T.ssAdd(fsys, T.semicolon), typedels), @lsp, @lsize)
    while nxt <> nil do
      align(lsp, @lc)
