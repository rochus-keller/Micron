end gen2

// pcom.pas lines 1904-1923: gentypindicator
proc gentypindicator(fsp: T.Stp)
begin
  if fsp <> nil then
    if fsp.form = T.scalar then
      if fsp = intptr then fWriteChar(prr, "i")
      elsif fsp = boolptr then fWriteChar(prr, "b")
      elsif fsp = charptr then fWriteChar(prr, "c")
      elsif fsp.scalkind = T.declared then fWriteChar(prr, "i")
      else fWriteChar(prr, "r") end
    elsif fsp.form = T.subrange then gentypindicator(fsp.rangetype)
    elsif fsp.form = T.pointer_f then fWriteChar(prr, "a")
    elsif fsp.form = T.power then fWriteChar(prr, "s")
    elsif (fsp.form = T.records) or (fsp.form = T.arrays) then fWriteChar(prr, "m")
    elsif (fsp.form = T.files) or (fsp.form = T.tagfld) or (fsp.form = T.variant_f) then
      error(500)
    end
  end
end gentypindicator

// pcom.pas lines 1925-1934: gen0t
proc gen0t(fop: integer; fsp: T.Stp)
begin
  if prcode then
    putic(); fWriteArr4(prr, mn[fop]); gentypindicator(fsp); fWriteLn(prr)
  end
  ic := ic + 1; mes(fop)
end gen0t

// pcom.pas lines 1936-1945: gen1t
proc gen1t(fop: integer; fp2: integer; fsp: T.Stp)
begin
  if prcode then
    putic(); fWriteArr4(prr, mn[fop]); gentypindicator(fsp)
    fWriteInt(prr, fp2, 11); fWriteLn(prr)
  end
  ic := ic + 1; mes(fop)
end gen1t

// pcom.pas lines 1947-1956: gen2t
proc gen2t(fop: integer; fp1, fp2: integer; fsp: T.Stp)
  var w: integer
begin
  if prcode then
    putic(); fWriteArr4(prr, mn[fop]); gentypindicator(fsp)
    if (fp1 > 99) or (fp1 < -99) then w := 8 else w := 3 end
    fWriteInt(prr, fp1, w); fWriteInt(prr, fp2, 8); fWriteLn(prr)
  end
  ic := ic + 1; mes(fop)
end gen2t

// pcom.pas lines 1958-1993: load
proc load()
begin
  if gattr.typtr <> nil then
    if gattr.kind = T.cst then
      if (gattr.typtr.form = T.scalar) and (gattr.typtr <> realptr) then
        if gattr.typtr = boolptr then gen2(51, 3, gattr.cval.ival)
        elsif gattr.typtr = charptr then gen2(51, 6, gattr.cval.ival)
        else gen2(51, 1, gattr.cval.ival) end
      else
        if gattr.typtr = nilptr then gen2(51, 4, 0)
        else
          if cstptrix >= cstoccmax then error(254)
          else
            inc(cstptrix)
            cstptr[cstptrix] := gattr.cval.valp
            if gattr.typtr = realptr then gen2(51, 2, cstptrix)
            else gen2(51, 5, cstptrix) end
          end
        end
      end
    elsif gattr.kind = T.varbl then
      if gattr.access = T.drct then
        if gattr.vlevel <= 1 then gen1t(39, gattr.dplmt, gattr.typtr)
        else gen2t(54, level - gattr.vlevel, gattr.dplmt, gattr.typtr) end
      elsif gattr.access = T.indrct then
        gen1t(35, gattr.idplmt, gattr.typtr)
      elsif gattr.access = T.inxd then error(400) end
    // expr: nothing to do
    end
    gattr.kind := T.expr
  end
end load

// pcom.pas lines 1995-2006: store
proc store(lattr: T.Attr)
begin
  if lattr.typtr <> nil then
    if lattr.access = T.drct then
      if lattr.vlevel <= 1 then gen1t(43, lattr.dplmt, lattr.typtr)
      else gen2t(56, level - lattr.vlevel, lattr.dplmt, lattr.typtr) end
    elsif lattr.access = T.indrct then
      if lattr.idplmt <> 0 then error(400)
      else gen0t(26, lattr.typtr) end
    elsif lattr.access = T.inxd then error(400) end
  end
end store

// pcom.pas lines 2008-2033: loadaddress
proc loadaddress()
begin
  if gattr.typtr <> nil then
    if gattr.kind = T.cst then
      if isString(gattr.typtr) then
        if cstptrix >= cstoccmax then error(254)
        else
          inc(cstptrix)
          cstptr[cstptrix] := gattr.cval.valp
          gen1(38, cstptrix)
        end
      else error(400) end
    elsif gattr.kind = T.varbl then
      if gattr.access = T.drct then
        if gattr.vlevel <= 1 then gen1(37, gattr.dplmt)
        else gen2(50, level - gattr.vlevel, gattr.dplmt) end
      elsif gattr.access = T.indrct then
        if gattr.idplmt <> 0 then gen1t(34, gattr.idplmt, nilptr) end
      elsif gattr.access = T.inxd then error(400) end
    elsif gattr.kind = T.expr then error(400) end
    gattr.kind := T.varbl; gattr.access := T.indrct; gattr.idplmt := 0
  end
end loadaddress

