  end procmnemonics

  // pcom.pas lines 3888-3906: instrmnemonics
  proc instrmnemonics()
  begin
    mn[ 0] := " abi"; mn[ 1] := " abr"; mn[ 2] := " adi"; mn[ 3] := " adr"
