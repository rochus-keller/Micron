// pcom.pas lines 3811-3821: initsets
proc initsets()
begin
  constbegsys := T.ss5(T.addop, T.intconst, T.realconst, T.stringconst, T.ident)
  simptypebegsys := T.ssAdd(constbegsys, T.lparent)
  typebegsys := T.ssUnion(T.ss6(T.arrow, T.packedsy, T.arraysy, T.recordsy, T.setsy, T.filesy), simptypebegsys)
  typedels := T.ss4(T.arraysy, T.recordsy, T.setsy, T.filesy)
  blockbegsys := T.ss7(T.labelsy, T.constsy, T.typesy, T.varsy, T.procsy, T.funcsy, T.beginsy)
  selectsys := T.ss3(T.arrow, T.period, T.lbrack)
  facbegsys := T.ss7(T.intconst, T.realconst, T.stringconst, T.ident, T.lparent, T.lbrack, T.notsy)
  statbegsys := T.ss8(T.beginsy, T.gotosy, T.ifsy, T.whilesy, T.repeatsy, T.forsy, T.withsy, T.casesy)
end initsets


