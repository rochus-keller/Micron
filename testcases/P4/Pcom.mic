// pcom.pas lines 855-862: skip
proc skip(fsys: T.SetOfSys)
begin
  if not F.Eof(srcfile) then
    while not T.symIn(fsys, sy) and not F.Eof(srcfile) do
      insymbol()
    end
    if not T.symIn(fsys, sy) then insymbol() end
  end
end skip


// pcom.pas lines 864-932: constant
proc constant(fsys: T.SetOfSys; fsp: ^T.Stp; fvalu: ^T.Valu)
  var lsp: T.Stp; lcp: T.Ctp; sign: integer  // 0=none, 1=pos, 2=neg
      lvp: T.Csp; i: integer
begin
  lsp := nil; fvalu.intval := true; fvalu.ival := 0
  if not T.symIn(constbegsys, sy) then
    error(50); skip(T.ssUnion(fsys, constbegsys))
  end
  if T.symIn(constbegsys, sy) then
    if sy = T.stringconst then
      if lgth = 1 then lsp := charptr
      else
        new(lsp)
        lsp.aeltype := charptr; lsp.inxtype := nil
        lsp.size := lgth * T.charsize; lsp.form := T.arrays
      end
      fvalu^ := val; insymbol()
    else
      sign := 0
      if (sy = T.addop) and ((op = T.plus) or (op = T.minus)) then
        if op = T.plus then sign := 1 else sign := 2 end
        insymbol()
      end
      if sy = T.ident then
        searchid(T.idBit(T.konst), @lcp)
        lsp := lcp.idtype; fvalu^ := lcp.values
        if sign <> 0 then
          if lsp = intptr then
            if sign = 2 then fvalu.ival := -fvalu.ival end
          elsif lsp = realptr then
            if sign = 2 then
              new(lvp); lvp.cclass := T.reel
              if fvalu.valp.rval[1] = "-" then
                lvp.rval[1] := "+"
              else lvp.rval[1] := "-" end
              for i := 2 to T.strglgth do
                lvp.rval[i] := fvalu.valp.rval[i]
              end
              fvalu.intval := false; fvalu.valp := lvp
            end
          else error(105) end
        end
        insymbol()
      elsif sy = T.intconst then
        if sign = 2 then val.ival := -val.ival end
        lsp := intptr; fvalu^ := val; insymbol()
      elsif sy = T.realconst then
        if sign = 2 then val.valp.rval[1] := "-" end
        lsp := realptr; fvalu^ := val; insymbol()
      else
        error(106); skip(fsys)
      end
    end
    if not T.symIn(fsys, sy) then
      error(6); skip(fsys)
    end
  end
  fsp^ := lsp
end constant


// pcom.pas lines 934-944: equalbounds
proc equalbounds(fsp1, fsp2: T.Stp): boolean
  var lmin1, lmin2, lmax1, lmax2: integer
begin
  if (fsp1 = nil) or (fsp2 = nil) then return true end
  getbounds(fsp1, @lmin1, @lmax1)
  getbounds(fsp2, @lmin2, @lmax2)
  return (lmin1 = lmin2) and (lmax1 = lmax2)
end equalbounds


// pcom.pas lines 946-1016: comptypes
proc comptypes(fsp1, fsp2: T.Stp): boolean
  var nxt1, nxt2: T.Ctp; comp: boolean
      ltestp1, ltestp2: T.Testp
begin
  if fsp1 = fsp2 then return true end
  if (fsp1 <> nil) and (fsp2 <> nil) then
    if fsp1.form = fsp2.form then
      if fsp1.form = T.scalar then return false
      elsif fsp1.form = T.subrange then
        return comptypes(fsp1.rangetype, fsp2.rangetype)
      elsif fsp1.form = T.pointer_f then
        comp := false; ltestp1 := globtestp; ltestp2 := globtestp
        while ltestp1 <> nil do
          if (ltestp1.elt1 = fsp1.eltype) and
             (ltestp1.elt2 = fsp2.eltype) then comp := true end
          ltestp1 := ltestp1.lasttestp
        end
        if not comp then
          new(ltestp1)
          ltestp1.elt1 := fsp1.eltype
          ltestp1.elt2 := fsp2.eltype
          ltestp1.lasttestp := globtestp
          globtestp := ltestp1
          comp := comptypes(fsp1.eltype, fsp2.eltype)
        end
        globtestp := ltestp2
        return comp
      elsif fsp1.form = T.power then
        return comptypes(fsp1.elset, fsp2.elset)
      elsif fsp1.form = T.arrays then
        comp := comptypes(fsp1.aeltype, fsp2.aeltype) and
                comptypes(fsp1.inxtype, fsp2.inxtype)
        return comp and (fsp1.size = fsp2.size) and
               equalbounds(fsp1.inxtype, fsp2.inxtype)
      elsif fsp1.form = T.records then
        nxt1 := fsp1.fstfld; nxt2 := fsp2.fstfld; comp := true
        while (nxt1 <> nil) and (nxt2 <> nil) do
          comp := comp and comptypes(nxt1.idtype, nxt2.idtype)
          nxt1 := nxt1.next; nxt2 := nxt2.next
        end
        return comp and (nxt1 = nil) and (nxt2 = nil) and
               (fsp1.recvar = nil) and (fsp2.recvar = nil)
      elsif fsp1.form = T.files then
        return comptypes(fsp1.filtype, fsp2.filtype)
      end
    else
      if fsp1.form = T.subrange then
        return comptypes(fsp1.rangetype, fsp2)
      elsif fsp2.form = T.subrange then
        return comptypes(fsp1, fsp2.rangetype)
      else return false end
    end
  else return true end
  return false
end comptypes

// pcom.pas lines 1018-1023: string test
proc isString(fsp: T.Stp): boolean
begin
  if fsp <> nil then
    if fsp.form = T.arrays then
      if comptypes(fsp.aeltype, charptr) then return true end
    end
  end
  return false
end isString


// pcom.pas lines 1029-1112: simpletype
proc simpletype(fsys: T.SetOfSys; fsp: ^T.Stp; fsize: ^integer)
  var lsp, lsp1: T.Stp; lcp, lcp1: T.Ctp; ttop: integer
      lcnt: integer; lvalu: T.Valu
begin
  fsize^ := 1
  if not T.symIn(simptypebegsys, sy) then
    error(1); skip(T.ssUnion(fsys, simptypebegsys))
  end
  if T.symIn(simptypebegsys, sy) then
    if sy = T.lparent then
      // pcom.pas lines 1037-1063: enumeration type
      ttop := top
      while display[top].occur <> T.blck do dec(top) end
      new(lsp)
      lsp.size := T.intsize; lsp.form := T.scalar
      lsp.scalkind := T.declared; lsp.fconst := nil
      lcp1 := nil; lcnt := 0
      loop
        insymbol()
        if sy = T.ident then
          new(lcp)
          lcp.name := id; lcp.idtype := lsp; lcp.next := lcp1
          lcp.values.intval := true; lcp.values.ival := lcnt
          lcp.klass := T.konst
          enterid(lcp)
          inc(lcnt); lcp1 := lcp; insymbol()
        else error(2) end
        if not T.symIn(T.ssAdd(T.ssAdd(fsys, T.comma), T.rparent), sy) then
          error(6); skip(T.ssAdd(T.ssAdd(fsys, T.comma), T.rparent))
        end
        if sy <> T.comma then goto enum_done end
      end
      enum_done:
      lsp.fconst := lcp1; top := ttop
      if sy = T.rparent then insymbol() else error(4) end
    else
      // pcom.pas lines 1065-1111: ident or constant subrange
      if sy = T.ident then
        searchid(T.idBit(T.types) + T.idBit(T.konst), @lcp)
        insymbol()
        if lcp.klass = T.konst then
          new(lsp); lsp.form := T.subrange
          lsp.rangetype := lcp.idtype
          if isString(lsp.rangetype) then
            error(148); lsp.rangetype := nil
          end
          lsp.min := lcp.values; lsp.size := T.intsize
          if sy = T.colon then insymbol() else error(5) end
          constant(fsys, @lsp1, @lvalu)
          lsp.max := lvalu
          if lsp.rangetype <> lsp1 then error(107) end
        else
          lsp := lcp.idtype
          if lsp <> nil then fsize^ := lsp.size end
        end
      else
        new(lsp); lsp.form := T.subrange
        constant(T.ssAdd(fsys, T.colon), @lsp1, @lvalu)
        if isString(lsp1) then error(148); lsp1 := nil end
        lsp.rangetype := lsp1; lsp.min := lvalu; lsp.size := T.intsize
        if sy = T.colon then insymbol() else error(5) end
        constant(fsys, @lsp1, @lvalu)
        lsp.max := lvalu
        if lsp.rangetype <> lsp1 then error(107) end
      end
      if lsp <> nil then
        if lsp.form = T.subrange then
          if lsp.rangetype <> nil then
            if lsp.rangetype = realptr then error(399)
            elsif lsp.min.ival > lsp.max.ival then error(102)
            end
          end
        end
      end
    end
    fsp^ := lsp
    if not T.symIn(fsys, sy) then error(6); skip(fsys) end
  else fsp^ := nil end
end simpletype


// pcom.pas lines 1114-1244: fieldlist
proc fieldlist(fsys: T.SetOfSys; frecvar: ^T.Stp; displ: ^integer)
  var lcp, lcp1, nxt, nxt1: T.Ctp
      lsp, lsp1, lsp2, lsp3, lsp4: T.Stp
      minsize, maxsize, lsize: integer
      lvalu: T.Valu
begin
  nxt1 := nil; lsp := nil
  if not T.symIn(T.ssAdd(T.ssAdd(fsys, T.ident), T.casesy), sy) then
    error(19); skip(T.ssAdd(T.ssAdd(fsys, T.ident), T.casesy))
  end
  while sy = T.ident do
    nxt := nxt1
    loop
      if sy = T.ident then
        new(lcp)
        lcp.name := id; lcp.idtype := nil; lcp.next := nxt
        lcp.klass := T.field; lcp.fldaddr := 0
        nxt := lcp; enterid(lcp); insymbol()
      else error(2) end
      if not T.symIn(T.ss2(T.comma, T.colon), sy) then
        error(6); skip(T.ss4(T.comma, T.colon, T.semicolon, T.casesy))
      end
      if sy <> T.comma then goto fld_done end
      insymbol()
    end
    fld_done:
    if sy = T.colon then insymbol() else error(5) end
    typ(T.ssAdd(T.ssAdd(fsys, T.casesy), T.semicolon), @lsp, @lsize)
    while nxt <> nxt1 do
      align(lsp, displ)
      nxt.idtype := lsp; nxt.fldaddr := displ^
      nxt := nxt.next; displ^ := displ^ + lsize
    end
    nxt1 := lcp
    while sy = T.semicolon do
      insymbol()
      if not T.symIn(T.ssAdd(T.ssAdd(T.ssAdd(fsys, T.ident), T.casesy), T.semicolon), sy) then
        error(19); skip(T.ssAdd(T.ssAdd(fsys, T.ident), T.casesy))
      end
    end
  end
  // reverse the field list
  nxt := nil
  while nxt1 <> nil do
    lcp := nxt1.next; nxt1.next := nxt; nxt := nxt1; nxt1 := lcp
  end
  if sy = T.casesy then
    // pcom.pas lines 1159-1242: variant part
    new(lsp); lsp.form := T.tagfld
    lsp.tagfieldp := nil; lsp.fstvar := nil
    frecvar^ := lsp
    insymbol()
    if sy = T.ident then
      new(lcp)
      lcp.name := id; lcp.idtype := nil; lcp.klass := T.field
      lcp.next := nil; lcp.fldaddr := displ^
      enterid(lcp); insymbol()
      if sy = T.colon then insymbol() else error(5) end
      if sy = T.ident then
        searchid(T.idBit(T.types), @lcp1)
        lsp1 := lcp1.idtype
        if lsp1 <> nil then
          align(lsp1, displ)
          lcp.fldaddr := displ^
          displ^ := displ^ + lsp1.size
          if (ord(lsp1.form) <= ord(T.subrange)) or isString(lsp1) then
            if comptypes(realptr, lsp1) then error(109)
            elsif isString(lsp1) then error(399)
            else
              lcp.idtype := lsp1; lsp.tagfieldp := lcp
            end
          else error(110) end
        end
        insymbol()
      else error(2); skip(T.ssAdd(T.ssAdd(fsys, T.ofsy), T.lparent)) end
    else error(2); skip(T.ssAdd(T.ssAdd(fsys, T.ofsy), T.lparent)) end
    lsp.size := displ^
    if sy = T.ofsy then insymbol() else error(8) end
    lsp1 := nil; minsize := displ^; maxsize := displ^
    loop
      lsp2 := nil
      if not T.symIn(T.ssAdd(fsys, T.semicolon), sy) then
        loop
          constant(T.ss3(T.comma, T.colon, T.lparent), @lsp3, @lvalu)
          if lsp.tagfieldp <> nil then
            if not comptypes(lsp.tagfieldp.idtype, lsp3) then error(111) end
          end
          new(lsp3); lsp3.form := T.variant_f
          lsp3.nxtvar := lsp1; lsp3.subvar := lsp2; lsp3.varval := lvalu
          lsp4 := lsp1
          while lsp4 <> nil do
            if lsp4.varval.ival = lvalu.ival then error(178) end
            lsp4 := lsp4.nxtvar
          end
          lsp1 := lsp3; lsp2 := lsp3
          if sy <> T.comma then goto var_done end
          insymbol()
        end
        var_done:
        if sy = T.colon then insymbol() else error(5) end
        if sy = T.lparent then insymbol() else error(9) end
        fieldlist(T.ssAdd(T.ssAdd(fsys, T.rparent), T.semicolon), @lsp2, displ)
        if displ^ > maxsize then maxsize := displ^ end
        while lsp3 <> nil do
          lsp4 := lsp3.subvar; lsp3.subvar := lsp2
          lsp3.size := displ^; lsp3 := lsp4
        end
        if sy = T.rparent then
          insymbol()
          if not T.symIn(T.ssAdd(fsys, T.semicolon), sy) then
            error(6); skip(T.ssAdd(fsys, T.semicolon))
          end
        else error(4) end
      end
      if sy <> T.semicolon then goto variant_done end
      displ^ := minsize; insymbol()
    end
    variant_done:
    displ^ := maxsize; lsp.fstvar := lsp1
  else frecvar^ := nil end
end fieldlist

// pcom.pas lines 1246-1385: typ
proc typ(fsys: T.SetOfSys; fsp: ^T.Stp; fsize: ^integer)
  var lsp, lsp1, lsp2: T.Stp; oldtop: integer; lcp: T.Ctp
      lsize, displ: integer; lmin, lmax: integer
begin
  if not T.symIn(typebegsys, sy) then
    error(10); skip(T.ssUnion(fsys, typebegsys))
  end
  if T.symIn(typebegsys, sy) then
    if T.symIn(simptypebegsys, sy) then
      simpletype(fsys, fsp, fsize)
    elsif sy = T.arrow then
      // pcom.pas lines 1253-1278: pointer type
      new(lsp); fsp^ := lsp
      lsp.eltype := nil; lsp.size := T.ptrsize; lsp.form := T.pointer_f
      insymbol()
      if sy = T.ident then
        prterr := false
        searchid(T.idBit(T.types), @lcp)
        prterr := true
        if lcp = nil then
          // forward referenced type id
          new(lcp)
          lcp.name := id; lcp.idtype := lsp
          lcp.next := fwptr; lcp.klass := T.types
          fwptr := lcp
        else
          if lcp.idtype <> nil then
            if lcp.idtype.form = T.files then error(108)
            else lsp.eltype := lcp.idtype end
          end
        end
        insymbol()
      else error(2) end
    else
      // packed, array, record, set, file
      if sy = T.packedsy then
        insymbol()
        if not T.symIn(typedels, sy) then
          error(10); skip(T.ssUnion(fsys, typedels))
        end
      end
      if sy = T.arraysy then
        // pcom.pas lines 1288-1327: array type
        insymbol()
        if sy = T.lbrack then insymbol() else error(11) end
        lsp1 := nil
        loop
          new(lsp)
          lsp.aeltype := lsp1; lsp.inxtype := nil; lsp.form := T.arrays
          lsp1 := lsp
          simpletype(T.ss3(T.comma, T.rbrack, T.ofsy), @lsp2, @lsize)
          lsp1.size := lsize
          if lsp2 <> nil then
            if ord(lsp2.form) <= ord(T.subrange) then
              if lsp2 = realptr then error(109); lsp2 := nil
              elsif lsp2 = intptr then error(149); lsp2 := nil
              else lsp.inxtype := lsp2 end
            else error(113); lsp2 := nil end
          end
          if sy <> T.comma then goto arr_done end
          insymbol()
        end
        arr_done:
        if sy = T.rbrack then insymbol() else error(12) end
        if sy = T.ofsy then insymbol() else error(8) end
        typ(fsys, @lsp, @lsize)
        loop
          lsp2 := lsp1.aeltype; lsp1.aeltype := lsp
          if lsp1.inxtype <> nil then
            getbounds(lsp1.inxtype, @lmin, @lmax)
            align(lsp, @lsize)
            lsize := lsize * (lmax - lmin + 1)
            lsp1.size := lsize
          end
          lsp := lsp1; lsp1 := lsp2
          if lsp1 = nil then goto arr_chain_done end
        end
        arr_chain_done:
      elsif sy = T.recordsy then
        // pcom.pas lines 1329-1350: record type
        insymbol()
        oldtop := top
        if top < T.displimit then
          inc(top)
          display[top].fname := nil
          display[top].flabel := nil
          display[top].occur := T.rec
        else error(250) end
        displ := 0
        fieldlist(T.ssAdd(fsys, T.endsy), @lsp1, @displ)
        new(lsp)
        lsp.fstfld := display[top].fname
        lsp.recvar := lsp1; lsp.size := displ; lsp.form := T.records
        top := oldtop
        if sy = T.endsy then insymbol() else error(13) end
      elsif sy = T.setsy then
        // pcom.pas lines 1352-1372: set type
        insymbol()
        if sy = T.ofsy then insymbol() else error(8) end
        simpletype(fsys, @lsp1, @lsize)
        if lsp1 <> nil then
          if ord(lsp1.form) > ord(T.subrange) then
            error(115); lsp1 := nil
          elsif lsp1 = realptr then error(114); lsp1 := nil
          elsif lsp1 = intptr then error(169); lsp1 := nil
          else
            getbounds(lsp1, @lmin, @lmax)
            if (lmin < T.setlow) or (lmax > T.sethigh) then error(169) end
          end
        end
        new(lsp)
        lsp.elset := lsp1; lsp.size := T.setsize; lsp.form := T.power
      elsif sy = T.filesy then
        // pcom.pas lines 1374-1377: file type
        insymbol()
        error(399); skip(fsys); lsp := nil
      end
      fsp^ := lsp
    end
    if not T.symIn(fsys, sy) then error(6); skip(fsys) end
  else fsp^ := nil end
  if fsp^ = nil then fsize^ := 1 else fsize^ := fsp^.size end
end typ


// pcom.pas lines 1387-1415: labeldeclaration
proc labeldeclaration(fsys: T.SetOfSys)
  var llp: T.Lbp; redef: boolean; lbname: integer
begin
  loop
    if sy = T.intconst then
      llp := display[top].flabel; redef := false
      while (llp <> nil) and not redef do
        if llp.labval <> val.ival then
          llp := llp.nextlab
        else redef := true; error(166) end
      end
      if not redef then
        new(llp)
        llp.labval := val.ival
        genlabel(@lbname)
        llp.defined := false; llp.nextlab := display[top].flabel
        llp.labname := lbname
        display[top].flabel := llp
      end
      insymbol()
    else error(15) end
    if not T.symIn(T.ssAdd(T.ssAdd(fsys, T.comma), T.semicolon), sy) then
      error(6); skip(T.ssAdd(T.ssAdd(fsys, T.comma), T.semicolon))
    end
    if sy <> T.comma then goto label_done end
    insymbol()
  end
  label_done:
  if sy = T.semicolon then insymbol() else error(14) end
end labeldeclaration


// pcom.pas lines 1417-1438: constdeclaration
proc constdeclaration(fsys: T.SetOfSys)
  var lcp: T.Ctp; lsp: T.Stp; lvalu: T.Valu
begin
  if sy <> T.ident then error(2); skip(T.ssAdd(fsys, T.ident)) end
  while sy = T.ident do
