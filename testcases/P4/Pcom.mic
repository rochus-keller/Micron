  ucstptr.values.ival := 0; ucstptr.klass := T.konst

  new(uvarptr)
  uvarptr.name := "        "; uvarptr.idtype := nil; uvarptr.vkind := T.actual
  uvarptr.next := nil; uvarptr.vlev := 0; uvarptr.vaddr := 0
  uvarptr.klass := T.vars

  new(ufldptr)
