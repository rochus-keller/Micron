    rsy[31] := T.packedsy;  rsy[32] := T.forwardsy; rsy[33] := T.progsy
    rsy[34] := T.funcsy;    rsy[35] := T.procsy
    ssy[ord("+")] := T.addop;    ssy[ord("-")] := T.addop;    ssy[ord("*")] := T.mulop
    ssy[ord("/")] := T.mulop;    ssy[ord("(")] := T.lparent;  ssy[ord(")")] := T.rparent
    ssy[ord("$")] := T.othersy;  ssy[ord("=")] := T.relop;    ssy[ord(" ")] := T.othersy
    ssy[ord(",")] := T.comma;    ssy[ord(".")] := T.period;   ssy[ord("'")] := T.othersy
    ssy[ord("[")] := T.lbrack;   ssy[ord("]")] := T.rbrack;   ssy[ord(":")] := T.colon
    ssy[ord("^")] := T.arrow;    ssy[ord("<")] := T.relop;    ssy[ord(">")] := T.relop
