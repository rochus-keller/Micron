  procedure primitiveObjectAt() 
  var index: Int; thisReceiver: OOP
  begin 
    TRACE_PRIMITIVE()
    index := popInteger()
    thisReceiver := popStack()
    successUpdate( index > 0)
    successUpdate( usig(index) <= OM.objectPointerCountOf(thisReceiver) )
    if success then
      push( OM.fetchPointerOfObject(usig(index-1), thisReceiver) )
    else unPop(2) end
  end primitiveObjectAt

  procedure primitiveObjectAtPut() 
  var newValue, thisReceiver: OOP; index: Int
  begin 
    TRACE_PRIMITIVE()
    newValue := popStack()
    index := popInteger()
    thisReceiver := popStack()
    successUpdate( index > 0)
    successUpdate( usig(index) <= ( OM.objectPointerCountOf(thisReceiver) ) )
    if success then
      OM.storePointerOfObject(usig(index-1), thisReceiver, newValue )
      push( newValue )
    else unPop(3) end
  end primitiveObjectAtPut

  procedure primitiveQuo()
  var integerArgument, integerReceiver: real
      integerResult: Int
  begin 
    TRACE_PRIMITIVE()
    integerArgument := flt(popInteger())
    integerReceiver := flt(popInteger())
    successUpdate( integerArgument # 0.0 )
    integerResult := 0
    if success then
      integerResult := val(Int, floor( integerReceiver / integerArgument + 0.5 ))
      successUpdate( OM.isIntegerValue(usig(integerResult)) )
    end
    if success then
      pushInteger( integerResult )
    else
      unPop(2)
    end
  end primitiveQuo

