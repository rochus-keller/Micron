	procedure primitiveAdd()
	var integerArgument, integerReceiver: Int
	    integerResult: int32
	begin 
    integerArgument := popInteger()
    integerReceiver := popInteger()
    integerResult := 0
    if success then
      integerResult := val(int32, integerReceiver) + val(int32, integerArgument)
      successUpdate( (integerResult >= -16384) and (integerResult <= 16383) )
    end
    if success then
      pushInteger( val(Int, integerResult) )
    else 
      unPop(2) 
    end
	end primitiveAdd

