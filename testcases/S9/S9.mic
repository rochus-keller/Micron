  add_primitive("list", P.pp_list, 0, -1, T.T_NONE, T.T_NONE, T.T_NONE)
  add_primitive("length", P.pp_length, 1, 1, T.T_PAIR_OR_NIL, T.T_NONE, T.T_NONE)
  add_primitive("reverse", P.pp_reverse, 1, 1, T.T_PAIR_OR_NIL, T.T_NONE, T.T_NONE)
  add_primitive("append2", P.pp_append2, 2, 2, T.T_PAIR_OR_NIL, T.T_NONE, T.T_NONE)
