(* S9 - Main module for S9 Scheme interpreter
 * Micron port of "Scheme 9 from Empty Space" by Nils M Holm, 2007-2014
 * Migrated from C in 2026 by me@rochus-keller.ch, made available under
 * the terms of the GNU General Public License (GPL) versions 2.0 or 3.0 
 *
 * This module contains:
 * - Initialization
 * - REPL (Read-Eval-Print Loop)
 * - Primitive registration
 * - Main entry point
 *)

module S9 [level=3]

import T := S9Types
import G := S9Globals
import M := S9Memory
import IO := S9IO
import E := S9Eval
import P := S9Prims
import Files

const
  Version* = "2014-07-25"
  DefaultLibraryPath* = ".:~/.s9fes:/usr/local/share/s9fes"

(* ============================================================
 * Error handling
 * ============================================================ *)

procedure print_error_form(n: T.cell)
begin
  G.Printer_limit := 50
  IO.print_form(n)
  G.Printer_limit := 0
end print_error_form

procedure print_calltrace()
var
  i: int32
  j: int32
begin
  j := G.Proc_ptr
  for i := 0 to G.Proc_max - 1 do
    dec(j)
    if j < 0 then j := G.Proc_max - 1 end
    if G.Called_procedures[j] = T._NIL then return end
    IO.pr("  ")
    IO.print_form(G.Called_procedures[j])
    IO.nl()
  end
end print_calltrace

procedure error*(const msg: pointer to array of char; expr: T.cell): T.cell
type Str = array of char
begin
  if G.Error_flag # 0 then
    return T._UNDEFINED
  end
  G.Error_flag := 1
  G.Output_port := G.Error_port
  if G.File_list # T._NIL then
    IO.pr(G.string(G.car(G.File_list))(Str))
    IO.pr(": ")
  end
  IO.ntoa(@G.Buf, G.Line_no, 0)
  IO.pr(@G.Buf)
  IO.pr(": ")
  IO.pr(msg)
  if expr # T._NOEXPR then
    IO.pr(": ")
    print_error_form(expr)
  end
  IO.nl()
  if G.Proc_max > 0 then
    print_calltrace()
  end
  return T._UNDEFINED
end error

procedure fatal*(const msg: pointer to array of char)
begin
  G.Output_port := G.Error_port
  IO.pr("fatal: ")
  IO.pr(msg)
  IO.nl()
  //IO.bye(1)
  halt(1)
end fatal

(* ============================================================
 * Load primitive (pp_load)
 * ============================================================ *)

procedure ^load*(file: pointer to array of char): int32

procedure pp_load(x: T.cell): T.cell
type Str = array of char
begin
  if val(int32, G.string_len(G.cadr(x))) > T.TokenLength then
    return G.error("load: path too long", G.cadr(x))
  end
  if load(G.string(G.cadr(x))(Str)) < 0 then
    return G.error("load: cannot open file", G.cadr(x))
  end
  return T._UNSPECIFIC
end pp_load

(* ============================================================
 * Primitive registration
 * ============================================================ *)

procedure grow_primitives()
var
  new_prims: pointer to array of T.Prim
  i: int32
begin
  G.Max_prims := G.Max_prims + T.PrimSegSize
  new(new_prims, G.Max_prims)
  if new_prims = nil then
    fatal("grow_primitives: out of physical memory")
  end
  if G.Primitives # nil then
    for i := 0 to G.Last_prim - 1 do
      new_prims[i] := G.Primitives[i]
    end
    dispose(G.Primitives)
  end
  G.Primitives := new_prims
end grow_primitives

procedure add_primitive(const name: pointer to array of char; 
            handler: T.PrimHandler;
            min_args: int32; max_args: int32;
            t1: int32; t2: int32; t3: int32)
var
  v: T.cell
  n: T.cell
begin
  if name = "apply" then
    G.Apply_magic := G.Last_prim
  end
  if name = "call/cc" then
    G.Callcc_magic := G.Last_prim
  end
  v := IO.symbol_ref(name)
  n := M.new_atom(G.Last_prim, T._NIL)
  n := M.new_atom(T.T_PRIMITIVE, n)
  if G.Last_prim >= G.Max_prims then
    grow_primitives()
  end
  G.Primitives[G.Last_prim].name := name
  G.Primitives[G.Last_prim].handler := handler
  G.Primitives[G.Last_prim].min_args := min_args
  G.Primitives[G.Last_prim].max_args := max_args
  G.Primitives[G.Last_prim].arg_types[0] := t1
  G.Primitives[G.Last_prim].arg_types[1] := t2
  G.Primitives[G.Last_prim].arg_types[2] := t3
  inc(G.Last_prim)
  G.Environment := E.extend(v, n, G.Environment)
end add_primitive

