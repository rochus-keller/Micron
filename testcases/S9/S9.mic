  add_primitive("unquote", P.pp_unquote, 1, 1, T.T_NONE, T.T_NONE, T.T_NONE)
  add_primitive("unquote-splicing", P.pp_unquote_splicing, 1, 1, T.T_NONE, T.T_NONE, T.T_NONE)
  add_primitive("file-exists?", P.pp_file_exists_p, 1, 1, T.T_STRING, T.T_NONE, T.T_NONE)
  add_primitive("delete-file", P.pp_delete_file, 1, 1, T.T_STRING, T.T_NONE, T.T_NONE)
  add_primitive("bit-op", P.pp_bit_op, 3, -1, T.T_INTEGER, T.T_INTEGER, T.T_INTEGER)
  
  (* Load primitive - registered here because load() is in this module *)
  add_primitive("load", pp_load, 1, 1, T.T_STRING, T.T_NONE, T.T_NONE)
  
  (* Real number primitives *)
  add_primitive("real?", P.pp_real_p, 1, 1, T.T_NONE, T.T_NONE, T.T_NONE)
  add_primitive("exact?", P.pp_exact_p, 1, 1, T.T_REAL, T.T_NONE, T.T_NONE)
  add_primitive("inexact?", P.pp_inexact_p, 1, 1, T.T_REAL, T.T_NONE, T.T_NONE)
  add_primitive("exact->inexact", P.pp_exact_to_inexact, 1, 1, T.T_REAL, T.T_NONE, T.T_NONE)
  add_primitive("inexact->exact", P.pp_inexact_to_exact, 1, 1, T.T_REAL, T.T_NONE, T.T_NONE)
  add_primitive("/", P.pp_divide, 1, -1, T.T_REAL, T.T_NONE, T.T_NONE)
  add_primitive("floor", P.pp_floor, 1, 1, T.T_REAL, T.T_NONE, T.T_NONE)
  add_primitive("mantissa", P.pp_mantissa, 1, 1, T.T_REAL, T.T_NONE, T.T_NONE)
  add_primitive("exponent", P.pp_exponent, 1, 1, T.T_REAL, T.T_NONE, T.T_NONE)
end register_core_primitives

(* ============================================================
 * Environment initialization
 * ============================================================ *)

procedure get_library_path(): T.cell
begin
  // TODO check S9FES_LIBRARY_PATH env var
  return IO.make_string(DefaultLibraryPath, sig(strlen(DefaultLibraryPath)))
end get_library_path

procedure make_initial_env()
var
  new_: T.cell
begin
  G.Environment := M.cons(T._NIL, T._NIL)
  G.Environment := E.extend(IO.symbol_ref("**"), T._NIL, G.Environment)
  G.S_latest := G.cadr(G.Environment)
  G.Environment := E.extend(IO.symbol_ref("*extensions*"), T._NIL, G.Environment)
  G.S_extensions := G.cadr(G.Environment)
  G.Environment := E.extend(IO.symbol_ref("*library-path*"), T._NIL, G.Environment)
  G.S_library_path := G.cadr(G.Environment)
  new_ := get_library_path()
  G.set_box_value(G.S_library_path, new_)
  G.Environment := E.extend(IO.symbol_ref("*loading*"), T._FALSE, G.Environment)
  G.S_loading := G.cadr(G.Environment)
  G.Apply_magic := -1
  G.Callcc_magic := -1
  G.Last_prim := 0
  G.Max_prims := 0
  grow_primitives()
  register_core_primitives()
  G.Environment := M.cons(G.Environment, T._NIL)
  G.Program := T._TRUE  (* or rehash() will not work *)
  E.rehash(G.car(G.Environment))
end make_initial_env

(* ============================================================
 * Initialization
 * ============================================================ *)

procedure init*()
var
  i: int32
begin
  (* Initialize ports *)
  for i := 2 to T.MaxPorts - 1 do
    G.Ports[i] := nil
  end
  G.Ports[0] := Files.System(Files.Stdin)
  G.Ports[1] := Files.System(Files.Stdout)
  G.Ports[2] := Files.System(Files.Stderr)
  G.Port_flags[0] := chr(T.LockTag)
  G.Port_flags[1] := chr(T.LockTag)
  G.Port_flags[2] := chr(T.LockTag)
  G.Input_port := 0
  G.Output_port := 1
  G.Error_port := 2
  
  (* Initialize memory pools *)
  G.Cons_segment_size := T.InitialSegmentSize
  G.Vec_segment_size := T.InitialSegmentSize
  G.Cons_pool_size := 0
  G.Vec_pool_size := 0
  G.Car := nil
  G.Cdr := nil
  G.Tag := nil
  G.Free_list := T._NIL
  G.Vectors := nil
  G.Free_vecs := 0
  G.Memory_limit_kn := T.DefaultLimitKn * 1024i
  
  (* Initialize stacks *)
  G.Stack := T._NIL
  G.Stack_bottom := T._NIL
  G.State_stack := T._NIL
  
  (* Initialize temporaries *)
  G.Tmp_car := T._NIL
  G.Tmp_cdr := T._NIL
  G.Tmp := T._NIL
  
  (* Initialize globals *)
  G.Symbols := T._NIL
  G.Program := T._NIL
  G.Proc_ptr := 0
  G.Proc_max := 3
  G.Environment := T._NIL
  G.Acc := T._NIL
  G.Trace_list := T._NIL
  G.Level := 0
  G.Line_no := 1
  G.Error_flag := 0
  G.Load_level := 0
  G.Displaying := 0
  G.Printer_limit := 0
  G.Quiet_mode := 0
  G.Run_stats := 0
  G.File_list := T._NIL
  G.Primitives := nil
  
  (* Allocate initial memory *)
  M.new_cons_segment()
  M.new_vec_segment()
  M.gc()
  
  (* Initialize special symbols *)
  G.S_arrow := IO.symbol_ref("=>")
  G.S_and := IO.symbol_ref("and")
  G.S_begin := IO.symbol_ref("begin")
  G.S_cond := IO.symbol_ref("cond")
  G.S_define := IO.symbol_ref("define")
  G.S_define_syntax := IO.symbol_ref("define-syntax")
  G.S_else := IO.symbol_ref("else")
  G.S_if := IO.symbol_ref("if")
  G.S_lambda := IO.symbol_ref("lambda")
  G.S_or := IO.symbol_ref("or")
  G.S_quasiquote := IO.symbol_ref("quasiquote")
  G.S_quote := IO.symbol_ref("quote")
  G.S_set_b := IO.symbol_ref("set!")
  G.S_unquote := IO.symbol_ref("unquote")
  G.S_unquote_splicing := IO.symbol_ref("unquote-splicing")
  
  (* Create initial environment *)
  make_initial_env()
  E.reset_calltrace()
  E.init_eval()
end init

(* ============================================================
 * REPL (Read-Eval-Print Loop)
 * ============================================================ *)

procedure clear_leftover_envs()
begin
  while G.cdr(G.Environment) # T._NIL do
    G.Environment := G.cdr(G.Environment)
  end
end clear_leftover_envs

procedure repl*()
var
  n: T.cell
  sane_env: T.cell
begin
  sane_env := M.cons(T._NIL, T._NIL)
  M.save(sane_env)
  
  loop
    IO.reset_tty()
    G.Error_flag := 0
    G.Input_port := 0
    G.Output_port := 1
    clear_leftover_envs()
    E.reset_calltrace()
    G.Car[sane_env] := G.Environment
    
    if G.Quiet_mode = 0 then
      IO.pr("> ")
      IO.flush()
    end
    
    G.Program := IO.xread()
    if G.Program = T.END_OF_FILE then
      exit
    end
    
    if G.Error_flag = 0 then
      n := E.eval(G.Program)
    end
    
    if (G.Error_flag = 0) & ~G.unspecific_p(n) then
      IO.print_form(n)
      IO.nl()
      G.set_box_value(G.S_latest, n)
    end
    
    if G.Error_flag # 0 then
      G.Environment := G.car(sane_env)
    end
  end
  
  M.unsave(1)
  IO.nl()
end repl

(* ============================================================
 * Load file
 * ============================================================ *)

procedure load*(file: pointer to array of char): int32
var
  n: T.cell
  outer_lno: int32
  new_port: int32
  old_port: int32
  outer_loading: T.cell
  root_env: T.cell
begin
  new_port := P.open_port(file, true)
  if new_port = -1 then
    return -1
  end
  G.Port_flags[new_port] := chr(bor(G.Port_flags[new_port], T.LockTag))
  G.File_list := M.cons(IO.make_string(file, sig(strlen(file))), G.File_list)
  M.save(G.Environment)
  while G.cdr(G.Environment) # T._NIL do
    G.Environment := G.cdr(G.Environment)
  end
  root_env := G.Environment
  outer_loading := G.box_value(G.S_loading)
  G.set_box_value(G.S_loading, T._TRUE)
  old_port := G.Input_port
  outer_lno := G.Line_no
  G.Line_no := 1
  
  loop
    if G.Error_flag # 0 then exit end
    G.Input_port := new_port
    n := IO.xread()
    G.Input_port := old_port
    if n = T.END_OF_FILE then
      exit
    end
    if G.Error_flag = 0 then
      n := E.eval(n)
      (* Restore root env in case xeval changed G.Environment *)
      G.Environment := root_env
    end
  end
  
  P.close_port(new_port)
  G.Line_no := outer_lno
  G.set_box_value(G.S_loading,outer_loading)
  G.File_list := G.cdr(G.File_list)
  E.rehash(G.car(G.Environment))
  G.Environment := M.unsave(1)
  return 0
end load

(* ============================================================
 * Usage and version info
 * ============================================================ *)

procedure usage()
begin
  IO.pr("Usage: s9 [-h?] [-gnqv] [-f prog [args]] [-m size[m]]")
  IO.nl()
  IO.pr("      [-l prog] [-t count] [-- [args]]")
  IO.nl()
end usage

procedure long_usage()
begin
  IO.nl()
  usage()
  IO.nl()
  IO.pr("-h        display this summary (also -?)")
  IO.nl()
  IO.pr("-f file [args]  run program and exit (implies -q)")
  IO.nl()
  IO.pr("-g        print GC summaries (-gg = more)")
  IO.nl()
  IO.pr("-l file     load program (may be repeated)")
  IO.nl()
  IO.pr("-m n[m]     set memory limit to nK (or nM) nodes")
  IO.nl()
  IO.pr("-q        be quiet (no banner, no prompt, exit on errors)")
  IO.nl()
  IO.pr("-t n      list up to N procedures in call traces")
  IO.nl()
  IO.pr("-v        print version and exit")
  IO.nl()
  IO.pr("-- [args]     pass subsequent arguments to program")
  IO.nl()
  IO.nl()
end long_usage

procedure version_info()
type Str = array of char
begin
  IO.nl()
  IO.pr("Scheme 9 from Empty Space by Nils M Holm")
  IO.nl()
  IO.nl()
  IO.pr("version:     ")
  IO.pr(Version)
  IO.pr(" (Micron port)")
  IO.nl()
  IO.pr("library path:  ")
  IO.pr(G.string(G.box_value(G.S_library_path))(Str))
  IO.nl()
  IO.pr("memory limit:  ")
  if G.Memory_limit_kn # 0 then
    IO.ntoa(@G.Buf, G.Memory_limit_kn div 1024, 0)
    IO.pr(@G.Buf)
    IO.pr("K nodes")
    IO.nl()
  else
    IO.pr("none")
    IO.nl()
  end
  IO.nl()
  IO.pr("This program is in the public domain.")
  IO.nl()
  IO.nl()
end version_info

(* ============================================================
 * Main entry point
 * ============================================================ *)

procedure try_load_s9(const dir: pointer to array of char): boolean
var
  libfile: array 256 of char
  j: int32
begin
  j := 0
  while dir[j] # 0X do
    libfile[j] := dir[j]
    inc(j)
  end
  libfile[j] := '/'; inc(j)
  libfile[j] := 's'; inc(j)
  libfile[j] := '9'; inc(j)
  libfile[j] := '.'; inc(j)
  libfile[j] := 's'; inc(j)
  libfile[j] := 'c'; inc(j)
  libfile[j] := 'm'; inc(j)
  libfile[j] := 0X
  return load(@libfile) = 0
end try_load_s9

procedure load_library()
begin
  (* Try "." first - the first entry of DefaultLibraryPath *)
  if try_load_s9(".") then return end
  error("load_library: cannot find s9.scm in library path", T._NOEXPR)
end load_library

procedure main*()
begin
  init()
  load_library()
  
  if G.Quiet_mode = 0 then
    IO.pr("Scheme 9 from Empty Space")
    IO.nl()
  end
  
  repl()
  IO.reset_tty()
end main

begin
  G.errorProc := error
  G.fatalProc := fatal
  main()
end S9.
