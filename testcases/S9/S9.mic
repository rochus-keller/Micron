  add_primitive("output-port?", P.pp_output_port_p, 1, 1, T.T_NONE, T.T_NONE, T.T_NONE)
  add_primitive("eof-object?", P.pp_eof_object_p, 1, 1, T.T_NONE, T.T_NONE, T.T_NONE)
  
  (* Pairs and Lists *)
  add_primitive("car", P.pp_car, 1, 1, T.T_PAIR, T.T_NONE, T.T_NONE)
  add_primitive("cdr", P.pp_cdr, 1, 1, T.T_PAIR, T.T_NONE, T.T_NONE)
