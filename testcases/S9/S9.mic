  add_primitive("eqv?", P.pp_eqv_p, 2, 2, T.T_NONE, T.T_NONE, T.T_NONE)
  add_primitive("not", P.pp_not, 1, 1, T.T_NONE, T.T_NONE, T.T_NONE)
  add_primitive("null?", P.pp_null_p, 1, 1, T.T_NONE, T.T_NONE, T.T_NONE)
  add_primitive("boolean?", P.pp_boolean_p, 1, 1, T.T_NONE, T.T_NONE, T.T_NONE)
  
  (* Type predicates *)
